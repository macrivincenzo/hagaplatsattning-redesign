---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Haga Plattsättning AB – Kakelsättare Stockholm',
  description = 'Professionell plattsättning och badrumsrenovering i Stockholm. Certifierade kakelsättare med garanti. Få gratis offert idag.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --color-primary: #1a1a2e;
        --color-accent: #c8a96e;
        --color-white: #ffffff;
        --color-light: #f7f7f7;
        --color-text: #333333;
        --color-muted: #666666;
        --font-sans: 'Segoe UI', system-ui, -apple-system, sans-serif;
      }
      html { scroll-behavior: smooth; }
      body { font-family: var(--font-sans); color: var(--color-text); background: var(--color-white); }
      a { text-decoration: none; color: inherit; }
      img { max-width: 100%; display: block; }

      /* ── TOP BAR ── */
      .topbar {
        background: var(--color-primary);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.5rem;
        min-height: 44px;
        gap: 1rem;
      }
      .topbar__phone {
        color: var(--color-white);
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        white-space: nowrap;
      }
      .topbar__phone a { color: var(--color-accent); font-weight: 600; }
      .topbar__reco {
        flex: 1;
        max-width: 600px;
        overflow: hidden;
      }
      .topbar__reco iframe {
        width: 100%;
        border: 0;
        display: block;
        overflow: hidden;
        height: 44px;
        pointer-events: auto;
      }

      /* ── NAV ── */
      .site-header {
        background: var(--color-white);
        border-bottom: 1px solid #e8e8e8;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      }
      .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 70px;
        gap: 2rem;
      }
      .nav-logo {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--color-primary);
        letter-spacing: -0.5px;
        flex-shrink: 0;
      }
      .nav-logo span { color: var(--color-accent); }
      .nav-links {
        display: flex;
        list-style: none;
        gap: 0.25rem;
        align-items: center;
      }
      .nav-links a {
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--color-text);
        border-radius: 4px;
        transition: background 0.15s, color 0.15s;
        white-space: nowrap;
      }
      .nav-links a:hover { background: var(--color-light); color: var(--color-primary); }
      .nav-cta {
        background: var(--color-accent);
        color: var(--color-primary) !important;
        font-weight: 700 !important;
        padding: 0.5rem 1.1rem !important;
        border-radius: 6px !important;
      }
      .nav-cta:hover { background: #b8995e !important; }
      .nav-hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        padding: 4px;
        background: none;
        border: none;
      }
      .nav-hamburger span {
        width: 24px;
        height: 2px;
        background: var(--color-primary);
        border-radius: 2px;
        display: block;
        transition: 0.3s;
      }

      /* ── FOOTER ── */
      .site-footer {
        background: var(--color-primary);
        color: var(--color-white);
      }
      .footer-reco {
        background: var(--color-white);
        padding: 0;
      }
      .footer-reco iframe {
        width: 100%;
        border: 0;
        display: block;
        overflow: hidden;
        height: 225px;
      }
      .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3rem 1.5rem 2rem;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 3rem;
      }
      .footer-brand h3 {
        font-size: 1.2rem;
        font-weight: 800;
        margin-bottom: 0.75rem;
        color: var(--color-accent);
      }
      .footer-brand p {
        font-size: 0.88rem;
        color: rgba(255,255,255,0.7);
        line-height: 1.6;
        max-width: 320px;
      }
      .footer-col h4 {
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-accent);
        margin-bottom: 1rem;
      }
      .footer-col ul { list-style: none; }
      .footer-col ul li { margin-bottom: 0.5rem; }
      .footer-col ul li a {
        font-size: 0.88rem;
        color: rgba(255,255,255,0.7);
        transition: color 0.15s;
      }
      .footer-col ul li a:hover { color: var(--color-white); }
      .footer-col address {
        font-style: normal;
        font-size: 0.88rem;
        color: rgba(255,255,255,0.7);
        line-height: 1.8;
      }
      .footer-col address a { color: var(--color-accent); }
      .footer-bottom {
        border-top: 1px solid rgba(255,255,255,0.1);
        padding: 1.25rem 1.5rem;
        text-align: center;
        font-size: 0.8rem;
        color: rgba(255,255,255,0.4);
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 768px) {
        .nav-links { display: none; }
        .nav-hamburger { display: flex; }
        .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
        .topbar__phone { display: none; }
        .topbar__reco { max-width: 100%; }
      }
    </style>
  </head>
  <body>

    <!-- ══ POSITION 1: TOP BAR — Reco widget ══ -->
    <div class="topbar">
      <p class="topbar__phone">
        Ring oss: <a href="tel:0739133348">073-913 33 48</a>
      </p>
      <div class="topbar__reco">
        <iframe
          src="https://widget.reco.se/v2/venues/4532782/horizontal/small?inverted=true&border=false&lang=sv"
          title="Haga Plattsättning AB - Omdömen på Reco"
          height="44"
          style="width:100%;border:0;display:block;overflow:hidden;"
          loading="lazy"
        ></iframe>
      </div>
    </div>

    <!-- ══ NAVIGATION ══ -->
    <header class="site-header">
      <nav class="nav-inner">
        <a href="/" class="nav-logo">Haga <span>Plattsättning</span></a>
        <ul class="nav-links">
          <li><a href="/">Hem</a></li>
          <li><a href="/om-oss">Om oss</a></li>
          <li><a href="/badrumsrenovering-stockholm">Badrumsrenovering</a></li>
          <li><a href="/kakelsattare-stockholm">Kakelsättning</a></li>
          <li><a href="/referensprojekt">Referensprojekt</a></li>
          <li><a href="/offert" class="nav-cta">Få offert</a></li>
        </ul>
        <button class="nav-hamburger" aria-label="Öppna meny">
          <span></span><span></span><span></span>
        </button>
      </nav>
    </header>

    <!-- ══ PAGE CONTENT ══ -->
    <main>
      <slot />
    </main>

    <!-- ══ FOOTER ══ -->
    <footer class="site-footer">

      <!-- ══ POSITION 3: FOOTER — Reco widget ══ -->
      <div class="footer-reco">
        <iframe
          src="https://widget.reco.se/v2/venues/4532782/horizontal/xlarge?inverted=false&border=false&lang=sv"
          title="Haga Plattsättning AB - Omdömen på Reco"
          height="225"
          style="width:100%;border:0;display:block;overflow:hidden;"
          loading="lazy"
        ></iframe>
      </div>

      <div class="footer-inner">
        <div class="footer-brand">
          <h3>Haga Plattsättning AB</h3>
          <p>Professionell plattsättning och badrumsrenovering i Stockholm sedan 2022. Vi följer Byggkeramikrådets branschregler (BBV) och levererar våtrumsintyg på allt utfört arbete.</p>
        </div>
        <div class="footer-col">
          <h4>Tjänster</h4>
          <ul>
            <li><a href="/badrumsrenovering-stockholm">Badrumsrenovering</a></li>
            <li><a href="/badrumsrenovering-pris">Priser &amp; offert</a></li>
            <li><a href="/kakelsattare-stockholm">Kakelsättning</a></li>
            <li><a href="/koksrenovering-stockholm">Köksrenovering</a></li>
            <li><a href="/referensprojekt">Referensprojekt</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Kontakt</h4>
          <address>
            Skyttevägen 6<br />
            192 58 Sollentuna<br /><br />
            <a href="tel:0739133348">073-913 33 48</a><br />
            <a href="https://www.reco.se/haga-plattsattning-ab-sollentuna" target="_blank" rel="noopener">Läs omdömen på Reco</a>
          </address>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; {new Date().getFullYear()} Haga Plattsättning AB. Alla rättigheter förbehållna.
      </div>
    </footer>

  </body>
</html>
