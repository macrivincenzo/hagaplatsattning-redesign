---
const path = Astro.url.pathname;
const isService = [
  '/badrumsrenovering-stockholm/',
  '/badrumsrenovering-sollentuna/',
  '/badrumsrenovering-solna/',
  '/badrumsrenovering-sundbyberg/',
  '/badrumsrenovering-lidingo/',
  '/badrumsrenovering-danderyd/',
  '/badrumsrenovering-taby/',
  '/badrumsrenovering-nacka/',
  '/kakelsattare-stockholm/',
  '/koksrenovering-stockholm/',
].includes(path);
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..600&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
<link rel="stylesheet" href="/design.css" />

<div class="reco-bar">
  <iframe src="https://widget.reco.se/v2/venues/4532782/horizontal/large?inverted=false&border=false&lang=sv" title="Haga Plattsättning AB - Omdömen på Reco" height="60" style="width:100%;border:0;display:block;overflow:hidden;" data-reactroot loading="lazy"></iframe>
</div>

<nav class="site-nav" aria-label="Huvudnavigation">
  <div class="nav-inner">
    <a href="/" class="nav-brand" aria-label="Haga Plattsättning AB – startsida">
      <img src="/Hagaplattsattninglogga-cleanbackground.png" alt="Haga Plattsättning AB" class="nav-logo" width="360" height="108" />
    </a>
    <ul class="nav-links" role="list">
      <li><a href="/" aria-current={path === '/' ? 'page' : undefined}>Hem</a></li>
      <li><a href="/om-oss/" aria-current={path === '/om-oss/' ? 'page' : undefined}>Om oss</a></li>
      <li class="nav-dropdown">
        <a href="/badrumsrenovering-stockholm/" aria-haspopup="true" aria-current={isService ? 'page' : undefined}>Tjänster</a>
        <div class="dropdown-menu" role="menu">
          <a href="/badrumsrenovering-stockholm/" role="menuitem">Badrumsrenovering Stockholm</a>
          <a href="/kakelsattare-stockholm/" role="menuitem">Kakelsättare Stockholm</a>
          <a href="/koksrenovering-stockholm/" role="menuitem">Köksrenovering Stockholm</a>
        </div>
      </li>
      <li><a href="/referensprojekt/" aria-current={path === '/referensprojekt/' ? 'page' : undefined}>Referensprojekt</a></li>
      <li><a href="/offertforfragan/" aria-current={path === '/offertforfragan/' ? 'page' : undefined}>Offertförfrågan</a></li>
    </ul>
    <div class="nav-cta-wrap">
      <a class="nav-phone" href="tel:0739133348">073-913 33 48</a>
      <a class="btn nav-cta-yellow" href="/offertforfragan/">Få gratis offert <span class="arrow">→</span></a>
      <button class="hamburger" aria-label="Öppna meny" aria-expanded="false" id="hamburger"><span></span><span></span><span></span></button>
    </div>
  </div>
  <div class="nav-mobile" id="mobile-menu" role="navigation" aria-label="Mobilmeny">
    <ul role="list">
      <li><a href="/">Hem</a></li>
      <li><a href="/om-oss/">Om oss</a></li>
    </ul>
    <span class="mobile-section">Tjänster</span>
    <ul role="list">
      <li><a href="/badrumsrenovering-stockholm/">Badrumsrenovering Stockholm</a></li>
      <li><a href="/kakelsattare-stockholm/">Kakelsättare Stockholm</a></li>
      <li><a href="/koksrenovering-stockholm/">Köksrenovering Stockholm</a></li>
    </ul>
    <ul role="list">
      <li><a href="/referensprojekt/">Referensprojekt</a></li>
      <li><a href="/offertforfragan/">Offertförfrågan</a></li>
    </ul>
    <div class="mobile-cta">
      <a class="btn btn-secondary" href="tel:0739133348">073-913 33 48</a>
      <a class="btn nav-cta-yellow" href="/offertforfragan/">Få gratis offert <span class="arrow">→</span></a>
    </div>
  </div>
</nav>

<!-- Mobile sticky CTA -->
<div class="m-sticky" role="region" aria-label="Snabb kontakt">
  <a href="tel:0739133348" class="btn btn-secondary">📞 Ring</a>
  <a href="/offertforfragan/" class="btn nav-cta-yellow" style="flex:1;justify-content:center">Få gratis offert <span class="arrow">→</span></a>
</div>

<script>
  const btn = document.getElementById('hamburger');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
