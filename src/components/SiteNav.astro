---
const path = Astro.url.pathname;
const isService = [
  '/badrumsrenovering-stockholm',
  '/badrumsrenovering-sollentuna',
  '/badrumsrenovering-solna',
  '/badrumsrenovering-pris',
  '/kakelsattare-stockholm',
  '/koksrenovering-stockholm',
].includes(path);
---

<style is:global>
  .reco-bar { width: 100%; overflow: hidden; }
  .reco-bar iframe { width: 100%; border: 0; display: block; overflow: hidden; height: 60px; }
  .contact-bar { background: #12122a; display: flex; align-items: center; justify-content: center; gap: 3rem; height: 44px; font-size: 0.88rem; }
  .contact-bar a { color: rgba(255,255,255,0.85); text-decoration: none; display: flex; align-items: center; gap: 0.4rem; transition: color 0.15s; }
  .contact-bar a:hover { color: #fff; }
  .site-nav { background: #ffffff; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 12px rgba(0,0,0,0.12); border-top: 1px solid rgba(230,57,70,0.15); }
  .nav-inner { max-width: 1400px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 128px; gap: 2rem; }
  .nav-brand { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; text-decoration: none; }
  .nav-logo { height: 96px; width: auto; display: block; }
  .nav-links { display: flex; align-items: center; list-style: none; gap: 0.1rem; flex: 1; justify-content: center; }
  .nav-links a { color: #e63946; text-decoration: none; font-size: 1.6rem; font-weight: 700; padding: 0.65rem 1rem; border-radius: 6px; transition: color 0.15s, background 0.15s; white-space: nowrap; }
  .nav-links a:hover { color: #c81f2d; background: rgba(230,57,70,0.08); }
  .nav-links a[aria-current="page"] { background: rgba(230,57,70,0.14); }
  .nav-dropdown { position: relative; }
  .nav-dropdown > a::after { content: ' ▾'; font-size: 1rem; opacity: 0.6; }
  .dropdown-menu { display: none; position: absolute; top: calc(100% + 8px); left: 0; background: #ffffff; border: 1px solid rgba(230,57,70,0.2); border-radius: 8px; padding: 0.5rem 0; min-width: 250px; box-shadow: 0 8px 24px rgba(0,0,0,0.18); z-index: 200; }
  .nav-dropdown:hover .dropdown-menu { display: block; }
  .dropdown-menu a { display: block; color: #e63946 !important; font-size: 1.15rem !important; font-weight: 600 !important; padding: 0.8rem 1.2rem !important; border-radius: 0 !important; background: none !important; white-space: nowrap; }
  .dropdown-menu a:hover { color: #c81f2d !important; background: rgba(230,57,70,0.08) !important; }
  .nav-cta { flex-shrink: 0; background: #ffffff; color: #e63946 !important; font-weight: 700 !important; font-size: 1.35rem !important; padding: 0.75rem 1.4rem !important; border-radius: 8px !important; border: 1px solid #e63946; transition: color 0.15s, background 0.15s !important; white-space: nowrap; text-decoration: none; }
  .nav-cta:hover { color: #ffffff !important; background: #e63946 !important; }
  .nav-hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; }
  .nav-hamburger span { display: block; width: 24px; height: 2px; background: #e63946; border-radius: 2px; transition: 0.25s; }
  .nav-mobile { display: none; flex-direction: column; background: #ffffff; border-top: 1px solid rgba(230,57,70,0.2); padding: 1rem 1.5rem 1.5rem; gap: 0.25rem; }
  .nav-mobile.open { display: flex; }
  .nav-mobile a { color: #e63946; text-decoration: none; font-size: 1.2rem; font-weight: 700; padding: 0.85rem 0; border-bottom: 1px solid rgba(230,57,70,0.12); transition: color 0.15s; }
  .nav-mobile a:hover { color: #c81f2d; }
  .nav-mobile .mobile-section { font-size: 0.95rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(230,57,70,0.65); padding: 0.9rem 0 0.35rem; }
  .nav-mobile .mobile-cta { margin-top: 0.9rem; background: #ffffff; color: #e63946 !important; font-weight: 700 !important; text-align: center; padding: 0.95rem !important; border-radius: 8px; border: 1px solid #e63946; border-bottom: 1px solid #e63946 !important; }
  .nav-mobile .mobile-cta:hover { background: #e63946; color: #ffffff !important; }
  @media (max-width: 900px) {
    .nav-links, .nav-cta { display: none; }
    .nav-hamburger { display: flex; }
    .nav-inner { height: 96px; }
    .nav-logo { height: 72px; }
  }
  @media (max-width: 500px) {
    .contact-bar { justify-content: space-around; gap: 0; }
  }
</style>

<div class="reco-bar">
  <iframe src="https://widget.reco.se/v2/venues/4532782/horizontal/large?inverted=false&border=false&lang=sv" title="Haga Plattsättning AB - Omdömen på Reco" height="60" style="width:100%;border:0;display:block;overflow:hidden;" data-reactroot></iframe>
</div>

<div class="contact-bar">
  <a href="tel:0739133348" aria-label="Ring oss">📞 073-913 33 48</a>
  <a href="mailto:kontakt@hagaplattsattning.se" aria-label="Skicka e-post">✉ kontakt@hagaplattsattning.se</a>
</div>

<nav class="site-nav" aria-label="Huvudnavigation">
  <div class="nav-inner">
    <a href="/" class="nav-brand" aria-label="Haga Plattsättning AB – startsida">
      <img src="/hagaplattsattninglogga.svg" alt="Haga Plattsättning AB" class="nav-logo" width="240" height="96" />
    </a>
    <ul class="nav-links" role="list">
      <li><a href="/" aria-current={path === '/' ? 'page' : undefined}>Hem</a></li>
      <li><a href="/om-oss" aria-current={path === '/om-oss' ? 'page' : undefined}>Om oss</a></li>
      <li class="nav-dropdown">
        <a href="#tjanster" aria-haspopup="true" aria-current={isService ? 'page' : undefined}>Tjänster</a>
        <div class="dropdown-menu" role="menu">
          <a href="/badrumsrenovering-stockholm" role="menuitem">Badrumsrenovering Stockholm</a>
          <a href="/kakelsattare-stockholm" role="menuitem">Kakelsättare Stockholm</a>
          <a href="/koksrenovering-stockholm" role="menuitem">Köksrenovering Stockholm</a>
          <a href="/badrumsrenovering-pris" role="menuitem">Badrumsrenovering Pris</a>
        </div>
      </li>
      <li><a href="/referensprojekt" aria-current={path === '/referensprojekt' ? 'page' : undefined}>Referensprojekt</a></li>
      <li><a href="/offertforfragan" aria-current={path === '/offertforfragan' ? 'page' : undefined}>Offertförfrågan</a></li>
    </ul>
    <a href="/offertforfragan" class="nav-cta" aria-label="Få gratis offert">Få offert</a>
    <button class="nav-hamburger" aria-label="Öppna meny" aria-expanded="false" id="hamburger"><span></span><span></span><span></span></button>
  </div>
  <div class="nav-mobile" id="mobile-menu" role="navigation" aria-label="Mobilmeny">
    <a href="/">Hem</a>
    <a href="/om-oss">Om oss</a>
    <span class="mobile-section">Tjänster</span>
    <a href="/badrumsrenovering-stockholm">Badrumsrenovering Stockholm</a>
    <a href="/kakelsattare-stockholm">Kakelsättare Stockholm</a>
    <a href="/koksrenovering-stockholm">Köksrenovering Stockholm</a>
    <a href="/badrumsrenovering-pris">Badrumsrenovering Pris</a>
    <a href="/referensprojekt">Referensprojekt</a>
    <a href="/offertforfragan">Offertförfrågan</a>
    <a href="/offertforfragan" class="mobile-cta">Få gratis offert</a>
  </div>
</nav>

<script>
  const btn = document.getElementById('hamburger');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
