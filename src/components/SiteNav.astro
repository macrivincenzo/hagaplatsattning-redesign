---
const path = Astro.url.pathname;
const isService = [
  '/badrumsrenovering-stockholm',
  '/badrumsrenovering-sollentuna',
  '/badrumsrenovering-solna',
  '/kakelsattare-stockholm',
  '/koksrenovering-stockholm',
].includes(path);
---

<style is:global>
  .reco-bar { width: 100%; overflow: hidden; }
  .reco-bar iframe { width: 100%; border: 0; display: block; overflow: hidden; height: 60px; }
  .site-nav {
    background: #ffffff;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 12px rgba(0,0,0,0.12);
    border-top: 1px solid rgba(230,57,70,0.15);
    transition: background-color 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .site-nav.nav-home {
    position: fixed;
    top: 60px;
    left: 0;
    right: 0;
    background: transparent;
    box-shadow: none;
    border-top: 0;
  }
  .site-nav.nav-home.is-scrolled {
    background: rgba(255,255,255,0.97);
    box-shadow: 0 2px 12px rgba(0,0,0,0.12);
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  .nav-inner { max-width: 1320px; margin: 0 auto; padding: 0 1.25rem; display: flex; align-items: center; justify-content: space-between; height: 84px; gap: 1rem; }
  .site-nav, .site-nav * { font-family: Arial, Helvetica, sans-serif; }
  .nav-brand { display: flex; align-items: center; flex-shrink: 0; text-decoration: none; }
  .nav-logo { height: 58px; width: auto; display: block; }
  .nav-links {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 0.2rem;
    margin-left: auto;
    flex: 0 1 auto;
    justify-content: flex-end;
  }
  .nav-links a { color: #111111; text-decoration: none; font-size: 1.02rem; font-weight: 600; padding: 0.5rem 0.62rem; border-radius: 6px; transition: color 0.15s, background 0.15s; white-space: nowrap; letter-spacing: 0.01em; }
  .nav-links a:hover { color: #000000; background: rgba(0,0,0,0.08); }
  .nav-links a[aria-current="page"] { background: rgba(0,0,0,0.12); }
  .nav-dropdown { position: relative; }
  .nav-dropdown > a::after { content: ' ▾'; font-size: 0.68rem; opacity: 0.65; }
  .dropdown-menu { display: none; position: absolute; top: calc(100% + 8px); left: 0; background: #ffffff; border: 1px solid rgba(230,57,70,0.2); border-radius: 8px; padding: 0.5rem 0; min-width: 250px; box-shadow: 0 8px 24px rgba(0,0,0,0.18); z-index: 200; }
  .nav-dropdown:hover .dropdown-menu { display: block; }
  .dropdown-menu a { display: block; color: #111111 !important; font-size: 0.8rem !important; font-weight: 600 !important; padding: 0.66rem 0.94rem !important; border-radius: 0 !important; background: none !important; white-space: nowrap; }
  .dropdown-menu a:hover { color: #000000 !important; background: rgba(0,0,0,0.08) !important; }
  .nav-hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; }
  .nav-hamburger span { display: block; width: 24px; height: 2px; background: #111111; border-radius: 2px; transition: 0.25s; }
  .nav-mobile { display: none; flex-direction: column; background: #ffffff; border-top: 1px solid rgba(230,57,70,0.2); padding: 1rem 1.5rem 1.5rem; gap: 0.25rem; }
  .nav-mobile.open { display: flex; }
  .nav-mobile a { color: #111111; text-decoration: none; font-size: 1.2rem; font-weight: 700; padding: 0.85rem 0; border-bottom: 1px solid rgba(0,0,0,0.12); transition: color 0.15s; }
  .nav-mobile a:hover { color: #000000; }
  .nav-mobile .mobile-section { font-size: 0.95rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(0,0,0,0.65); padding: 0.9rem 0 0.35rem; }

  .nav-home .nav-links a {
    color: #ffffff;
    text-shadow: 0 1px 8px rgba(0,0,0,0.34);
  }
  .nav-home .nav-links a:hover { color: #ffffff; background: rgba(255,255,255,0.12); }
  .nav-home .nav-links a[aria-current="page"] { background: rgba(255,255,255,0.18); }
  .nav-home .nav-hamburger span { background: #ffffff; }
  .nav-home:not(.is-scrolled) .dropdown-menu a {
    text-shadow: none;
  }
  .nav-home.is-scrolled .nav-links a {
    color: #111111;
    text-shadow: none;
  }
  .nav-home.is-scrolled .nav-links a:hover { color: #000000; background: rgba(0,0,0,0.08); }
  .nav-home.is-scrolled .nav-links a[aria-current="page"] { background: rgba(0,0,0,0.12); }

  @media (max-width: 900px) {
    .nav-links { display: none; margin-left: 0; }
    .nav-hamburger { display: flex; }
    .nav-inner { height: 72px; }
    .nav-logo { height: 52px; }
    .site-nav.nav-home {
      top: 60px;
      background: transparent;
      backdrop-filter: none;
      box-shadow: none;
      border-top: 0;
    }
    .site-nav.nav-home .nav-links a {
      color: #111111;
      text-shadow: none;
    }
    .site-nav.nav-home .nav-links a:hover { background: rgba(0,0,0,0.08); }
    .site-nav.nav-home .nav-links a[aria-current="page"] { background: rgba(0,0,0,0.12); }
    .site-nav.nav-home.is-scrolled {
      background: #111111;
      box-shadow: 0 2px 12px rgba(0,0,0,0.24);
      border-top: 0;
    }
    .site-nav.nav-home.is-scrolled .nav-hamburger span {
      background: #ffffff;
    }
  }
</style>

<div class="reco-bar">
  <iframe src="https://widget.reco.se/v2/venues/4532782/horizontal/large?inverted=false&border=false&lang=sv" title="Haga Plattsättning AB - Omdömen på Reco" height="60" style="width:100%;border:0;display:block;overflow:hidden;" data-reactroot></iframe>
</div>

<nav class:list={['site-nav', path === '/' && 'nav-home']} aria-label="Huvudnavigation">
  <div class="nav-inner">
    <a href="/" class="nav-brand" aria-label="Haga Plattsättning AB – startsida">
      <img src="/Hagaplattsattninglogga-cleanbackground.png" alt="Haga Plattsättning AB" class="nav-logo" width="360" height="108" />
    </a>
    <ul class="nav-links" role="list">
      <li><a href="/" aria-current={path === '/' ? 'page' : undefined}>Hem</a></li>
      <li><a href="/om-oss" aria-current={path === '/om-oss' ? 'page' : undefined}>Om oss</a></li>
      <li class="nav-dropdown">
        <a href="#tjanster" aria-haspopup="true" aria-current={isService ? 'page' : undefined}>Tjänster</a>
        <div class="dropdown-menu" role="menu">
          <a href="/badrumsrenovering-stockholm" role="menuitem">Badrumsrenovering Stockholm</a>
          <a href="/kakelsattare-stockholm" role="menuitem">Kakelsättare Stockholm</a>
          <a href="/koksrenovering-stockholm" role="menuitem">Köksrenovering Stockholm</a>
        </div>
      </li>
      <li><a href="/referensprojekt" aria-current={path === '/referensprojekt' ? 'page' : undefined}>Referensprojekt</a></li>
      <li><a href="/offertforfragan" aria-current={path === '/offertforfragan' ? 'page' : undefined}>Offertförfrågan</a></li>
    </ul>
    <button class="nav-hamburger" aria-label="Öppna meny" aria-expanded="false" id="hamburger"><span></span><span></span><span></span></button>
  </div>
  <div class="nav-mobile" id="mobile-menu" role="navigation" aria-label="Mobilmeny">
    <a href="/">Hem</a>
    <a href="/om-oss">Om oss</a>
    <span class="mobile-section">Tjänster</span>
    <a href="/badrumsrenovering-stockholm">Badrumsrenovering Stockholm</a>
    <a href="/kakelsattare-stockholm">Kakelsättare Stockholm</a>
    <a href="/koksrenovering-stockholm">Köksrenovering Stockholm</a>
    <a href="/referensprojekt">Referensprojekt</a>
    <a href="/offertforfragan">Offertförfrågan</a>
  </div>
</nav>

<script>
  const btn = document.getElementById('hamburger');
  const menu = document.getElementById('mobile-menu');
  const nav = document.querySelector<HTMLElement>('.site-nav.nav-home');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
  });

  if (nav) {
    const triggerSection = document.getElementById('certifiering-kvalitet') as HTMLElement | null;
    let triggerPoint = 40;

    const recalculateTriggerPoint = () => {
      if (!triggerSection) {
        triggerPoint = 40;
        return;
      }

      const navHeight = nav.offsetHeight || 0;
      const recoBarHeight = 60;
      triggerPoint = Math.max(0, triggerSection.offsetTop - navHeight - recoBarHeight);
    };

    const toggleScrolled = () => {
      nav.classList.toggle('is-scrolled', window.scrollY >= triggerPoint);
    };

    recalculateTriggerPoint();
    toggleScrolled();
    window.addEventListener('scroll', toggleScrolled, { passive: true });
    window.addEventListener('resize', () => {
      recalculateTriggerPoint();
      toggleScrolled();
    });
  }
</script>
