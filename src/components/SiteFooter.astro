---
export interface Props {
  /** Sid-specifik avslutning efter gemensam företagsintroduktion */
  pageFocus: string;
}

const { pageFocus } = Astro.props;

const BASE =
  'Haga Plattsättning AB är ett certifierat plattsättarföretag med verksamhet i Stockholm och hela Stockholmsregionen. Vi utför professionell badrumsrenovering, kakelsättning och köksrenovering med fokus på hög kvalitet, noggrant hantverk och transparenta priser. Alla våra arbeten utförs med våtrumsintyg enligt Byggkeramikrådets riktlinjer och BBV (Branschregler för Våtrum), vilket garanterar ett korrekt och hållbart resultat.';
---

<style>
  .site-footer {
    background: #000000;
    color: #fff;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.875rem;
    line-height: 1.65;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2.5rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.4fr;
    gap: 3rem;
  }
  .footer-heading {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    margin-bottom: 1rem;
  }
  .footer-brand-logo {
    height: 44px;
    width: auto;
    display: block;
    margin-bottom: 1rem;
  }
  .footer-brand-text {
    color: #fff;
    font-size: 0.85rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .footer-badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .footer-links a {
    color: #fff;
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .footer-links a:hover {
    color: #fff;
  }
  .footer-areas {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .footer-areas li {
    color: #fff;
    font-size: 0.84rem;
  }
  .footer-areas a {
    color: #fff;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-areas a:hover {
    color: rgba(255, 255, 255, 0.75);
  }
  .footer-contact-block {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin-bottom: 1.25rem;
  }
  .footer-contact-block a {
    color: #fff;
    text-decoration: none;
    transition: color 0.15s;
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
  }
  .footer-contact-block a:hover {
    color: #fff;
  }
  .footer-address {
    color: #fff;
    font-size: 0.84rem;
    font-style: normal;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }
  .footer-hours {
    color: #fff;
    font-size: 0.82rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .footer-hours strong {
    display: block;
    color: #fff;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.3rem;
  }
  .footer-cta {
    display: inline-block;
    background: #fff;
    color: #1a1a2e;
    font-weight: 700;
    font-size: 0.88rem;
    padding: 0.55rem 1.2rem;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.15s;
    text-align: center;
    width: 100%;
  }
  .footer-cta:hover {
    opacity: 0.88;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: #fff;
  }
  .footer-bottom a {
    color: #fff;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-bottom a:hover {
    color: rgba(255, 255, 255, 0.75);
  }
  .footer-bottom-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-col-brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 540px) {
    .footer-inner {
      grid-template-columns: 1fr;
      padding: 2.5rem 1.25rem 2rem;
    }
    .footer-col-brand {
      grid-column: auto;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<footer class="site-footer" aria-label="Sidfot">
  <div class="footer-inner">
    <div class="footer-col-brand">
      <a href="/" aria-label="Haga Plattsättning AB – startsida">
        <img src="/hagaplattsattninglogga.svg" alt="Haga Plattsättning AB logotyp" class="footer-brand-logo" width="120" height="44" />
      </a>
      <p class="footer-brand-text">{BASE} {pageFocus}</p>
      <div class="footer-badges">
        <a
          href="https://www.reco.se/haga-plattsattning-ab-sollentuna"
          target="_blank"
          rel="noopener"
          aria-label="Rekommenderat 2 år i rad – Reco"
        >
          <img
            src="https://www.reco.se/assets/images/badges/BadgeTwoYears.svg"
            alt="Rekommenderat 2 år i rad – Reco"
            width="56"
            height="56"
          />
        </a>
        <a
          href="https://www.reco.se/haga-plattsattning-ab-sollentuna"
          target="_blank"
          rel="noopener"
          aria-label="Rekommenderat företag 2025 – Reco"
        >
          <img
            src="https://www.reco.se/assets/images/badges/trust2025.svg"
            alt="Rekommenderat företag 2025 – Reco"
            width="56"
            height="56"
          />
        </a>
        <a
          href="https://www.reco.se/haga-plattsattning-ab-sollentuna"
          target="_blank"
          rel="noopener"
          aria-label="Rekommenderat företag 2024 – Reco"
        >
          <img
            src="https://www.reco.se/assets/images/badges/trust2024.svg"
            alt="Rekommenderat företag 2024 – Reco"
            width="56"
            height="56"
          />
        </a>
      </div>
    </div>
    <div>
      <p class="footer-heading">Våra tjänster</p>
      <ul class="footer-links" role="list">
        <li><a href="/badrumsrenovering-stockholm">Badrumsrenovering Stockholm</a></li>
        <li><a href="/badrumsrenovering-pris">Badrumsrenovering pris</a></li>
        <li><a href="/kakelsattare-stockholm">Kakelsättare Stockholm</a></li>
        <li><a href="/koksrenovering-stockholm">Köksrenovering Stockholm</a></li>
        <li><a href="/referensprojekt">Referensprojekt</a></li>
        <li><a href="/om-oss">Om oss</a></li>
        <li><a href="/offertforfragan">Offertförfrågan</a></li>
      </ul>
    </div>
    <div>
      <p class="footer-heading">Vi arbetar i hela Stockholmsregionen</p>
      <ul class="footer-areas" role="list">
        <li><a href="/badrumsrenovering-stockholm">Stockholm</a></li>
        <li><a href="/badrumsrenovering-sollentuna">Sollentuna</a></li>
        <li><a href="/badrumsrenovering-solna">Solna</a></li>
        <li>Sundbyberg</li>
        <li>Lidingö</li>
        <li>Danderyd</li>
        <li>Täby</li>
        <li>Nacka</li>
        <li>Bromma</li>
        <li>Järfälla</li>
        <li>Upplands Väsby</li>
      </ul>
    </div>
    <div>
      <p class="footer-heading">Kontakt</p>
      <address class="footer-address">
        Haga Plattsättning AB<br />
        Skyttevägen 6<br />
        192 58 Sollentuna
      </address>
      <div class="footer-contact-block">
        <a href="tel:0739133348" aria-label="Ring Haga Plattsättning">📞 073-913 33 48</a>
        <a href="mailto:kontakt@hagaplattsattning.se" aria-label="Maila Haga Plattsättning"
          >✉ kontakt@hagaplattsattning.se</a
        >
      </div>
      <div class="footer-hours">
        <strong>Öppettider</strong>
        Mån–Fre: 07:00–17:00<br />
        Lör–Sön: Stängt
      </div>
      <a href="/offertforfragan" class="footer-cta">Få gratis offert →</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© 2026 Haga Plattsättning AB &nbsp;·&nbsp; Org.nr: 559297-8505 &nbsp;·&nbsp; F-skatt</span>
    <nav class="footer-bottom-links" aria-label="Juridiska sidor">
      <a href="/integritetspolicy">Integritetspolicy</a>
      <a href="/cookies">Cookies</a>
    </nav>
  </div>
</footer>
