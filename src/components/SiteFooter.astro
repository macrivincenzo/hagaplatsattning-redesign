      </div>
      <div class="right">
        <span class="phone">073-913 33 48 · kontakt@hagaplattsattning.se</span>
        <a href="/offertforfragan/" class="btn btn-primary">Få gratis offert <span class="arrow">→</span></a>
      </div>
    </div>

    <div class="footer-grid">
      <div>
        <a href="/" aria-label="Haga Plattsättning AB – startsida">
          <img src="/Hagaplattsattninglogga.svg" alt="Haga Plattsättning AB logotyp" style="height:54px;width:auto;background:var(--paper);border-radius:8px;padding:6px 12px" width="220" height="64" loading="lazy" decoding="async" />
        </a>
        <p class="footer-brand-text brand-line">{BASE} {pageFocus}</p>
        <div class="footer-badges stamps">
