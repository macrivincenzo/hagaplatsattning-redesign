---
import SiteFooter from './SiteFooter.astro';
import SiteNav from './SiteNav.astro';
import RecoWidget from './RecoWidget.astro';
import type { BadrumsLocationContent } from '../data/badrumsLocations';
import { BUSINESS } from '../data/business';

export interface Props {
  content: BadrumsLocationContent;
}

const { content } = Astro.props;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Hem', item: 'https://www.hagaplattsattning.se/' },
    { '@type': 'ListItem', position: 2, name: 'Tjänster' },
    {
      '@type': 'ListItem',
      position: 3,
      name: `Badrumsrenovering ${content.city}`,
      item: `https://www.hagaplattsattning.se${content.route}`,
    },
  ],
};

const DEFAULT_REVIEWS = [
  {
    author: 'Edit W',
    date: '2026-04-08',
    rating: 5,
    text: 'Otroligt bra upplevelse, de visade stort engagemang i vårt projekt redan från start. Var både följsamma och flexibla med våra önskemål, men också drivande och initiativtagande med egna förbättringar och lösningar.',
  },
  {
    author: 'Adam K, VD Rikets Projektutveckling AB',
    date: '2025-11-08',
    rating: 5,
    text: 'Vi på Rikets Projektutveckling AB har anlitat Haga Plattsättning AB som underentreprenör vid flera tillfällen och kan varmt rekommendera dem.',
  },
];

const visibleReviews = content.reviews ?? DEFAULT_REVIEWS;

const reviewJsonLd = visibleReviews.map((rev) => ({
  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: { '@type': 'LocalBusiness', '@id': 'https://www.hagaplattsattning.se/#business', name: 'Haga Plattsättning AB' },
  reviewRating: { '@type': 'Rating', ratingValue: String(rev.rating), bestRating: '5' },
  author: { '@type': 'Person', name: rev.author },
  datePublished: rev.date,
  reviewBody: rev.text,
  publisher: { '@type': 'Organization', name: 'Reco.se' },
}));

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const localBusinessJsonLd = {
  ...BUSINESS,
  description: content.localBusinessDescription,
  knowsAbout: [
    'Badrumsrenovering',
    `Badrumsrenovering ${content.city}`,
    'Kakelsättning',
    'Plattsättning',
    'Våtrum',
    'BKR-behörighet',
  ],
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${content.seo.canonical}#service`,
  name: `Badrumsrenovering ${content.city}`,
  serviceType: 'Badrumsrenovering',
  provider: { '@id': 'https://www.hagaplattsattning.se/#business' },
  areaServed: content.city,
  url: content.seo.canonical,
  potentialAction: {
    '@type': 'RequestQuoteAction',
    target: 'https://www.hagaplattsattning.se/offertforfragan/',
  },
};

const relatedLinksIntroBySlug: Record<string, string> = {
  stockholm: 'Planerar du ett större projekt i Stockholm?',
  sollentuna: 'Behöver du hjälp i hela norrort från Sollentuna?',
  solna: 'Ska du jämföra tjänster för projekt i Solna med omnejd?',
};

const relatedLinksIntro =
  relatedLinksIntroBySlug[content.slug] ??
  `Planerar du ett större projekt i ${content.city}?`;
---

<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow,max-image-preview:large" />

    <title>{content.seo.title}</title>
    <meta name="description" content={content.seo.description} />
    <link rel="canonical" href={content.seo.canonical} />
    <link rel="alternate" hreflang="sv-SE" href={content.seo.canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:site_name" content="Haga Plattsättning AB" />
    <meta property="og:url" content={content.seo.canonical} />
    <meta property="og:title" content={content.seo.ogTitle} />
    <meta property="og:description" content={content.seo.ogDescription} />
    <meta property="og:image" content={content.seo.ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={content.seo.ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.seo.twitterTitle} />
    <meta name="twitter:description" content={content.seo.twitterDescription} />
    <meta name="twitter:image" content={content.seo.twitterImage} />

    <meta name="geo.region" content="SE-AB" />
    <meta name="geo.placename" content={content.seo.geoPlacename} />
    <meta name="geo.position" content={content.seo.geoPosition} />
  </head>
  <body>
    <SiteNav />

    <div class="page-header">
      <nav class="breadcrumb" aria-label="Brödsmulor">
        <a href="/">Hem</a> <span>›</span>
        <span>Tjänster</span> <span>›</span>
        <strong style="color:var(--ink)">{`Badrumsrenovering ${content.city}`}</strong>
      </nav>
    </div>

    <section class="s-hero" aria-label={`Badrumsrenovering ${content.city} - Haga Plattsättning AB`}>
      <div class="container">
        <div>
          <span class="eyebrow">Plattsättare i {content.city}</span>
          <h1 class="h-display" style="margin-top:18px">Badrumsrenovering<br /><em>{`i ${content.city}`}</em></h1>
          <p class="lede" style="margin-top:22px">{content.hero.lead}</p>
          <div class="hero-actions">
            <a href="/offertforfragan/" class="btn btn-primary">Få kostnadsfri offert <span class="arrow">→</span></a>
            <a href="#faq" class="btn-link">Vanliga frågor ↓</a>
          </div>
        </div>
        <div class="hero-media">
          <img
            src={content.hero.imageSrc}
            alt={content.hero.imageAlt}
            width="2400"
            height="1350"
            loading="eager"
            fetchpriority="high"
          />
          <span class="reco-badge">
            <img src="/hagaplattsattningbadge.svg" alt="Reco - Rekommenderat företag två år i rad" width="84" height="84" loading="eager" />
          </span>
        </div>
      </div>
    </section>

    <section class="cert-strip" aria-label="Certifieringar">
      <span class="item">Behörigt Våtrum</span>
      <span class="item">Säker Vatten</span>
      <span class="item">BKR-certifierad</span>
      <span class="item">F-skatt &amp; försäkrad</span>
      <span class="item">Kvalitetsdokument</span>
    </section>

    <section class="s-twocol" aria-label="BKR-behörighet och försäkringsskydd vid badrumsrenovering">
      <div class="container">
        <div>
          <span class="eyebrow section-label">Trygghet och försäkring</span>
          <h2 class="h-section" style="margin-top:14px">Vad händer om du renoverar badrummet utan <em>kvalitetsdokument?</em></h2>
          <div class="body-prose" style="margin-top:18px;max-width:54ch">
            <p>En felaktig våtrumslösning kan bli kostsam. Med dokumenterad BKR-process minskar du risken för ersättningstvist vid skada och får ett badrum som är byggt för lång livslängd.</p>
          </div>
          <ul class="bkr-checklist" aria-label="Vad BKR-behörighet ger dig">
            <li>Kvalitetsdokument som krävs av försäkringsbolag</li>
            <li>Tätskikt enligt gällande branschregler och BBV</li>
            <li>Dokumenterad egenkontroll under hela projektet</li>
            <li>Tydlig slutleverans som är enkel att spara till framtida försäljning</li>
          </ul>
          <div style="margin-top:28px;display:flex;gap:14px;flex-wrap:wrap">
            <a class="btn btn-primary" href="/offertforfragan/">Boka kostnadsfri offert <span class="arrow">→</span></a>
          </div>
        </div>
        {content.bkrImageSrc && (
          <div>
            <div class="media-card">
              <img
                src={content.bkrImageSrc}
                alt={content.bkrImageAlt ?? `BKR-behörig badrumsrenovering i ${content.city}`}
                width="580"
                height="480"
                loading="lazy"
              />
            </div>
          </div>
        )}
      </div>
    </section>

    <section class="guide-section" aria-label={`Komplett guide till badrumsrenovering i ${content.city}`}>
      <div class="guide-header">
        <span class="eyebrow section-label">{`Guide: Badrumsrenovering ${content.city}`}</span>
        <h2 class="h-section" style="margin-top:14px">{content.guideHeader.title}</h2>
        <p set:html={content.guideHeader.introHtml} />
      </div>

      {content.guideBlocks.map((block) => (
        <div class:list={['guide-block', block.gray && 'gray']}>
          <div class:list={['guide-block-inner', block.textOnly && 'text-only']}>
            {!block.textOnly && block.imageSrc && block.imageFirst && (
              <div class="guide-image">
                <img src={block.imageSrc} alt={block.imageAlt ?? block.title} width="800" height="500" loading="lazy" />
              </div>
            )}
            <div class="guide-text">
              <h3>{block.title}</h3>
              <div class="body-prose" set:html={block.bodyHtml} />
            </div>
            {!block.textOnly && block.imageSrc && !block.imageFirst && (
              <div class="guide-image">
                <img src={block.imageSrc} alt={block.imageAlt ?? block.title} width="800" height="500" loading="lazy" />
              </div>
            )}
          </div>
        </div>
      ))}
    </section>

    {content.reviews && content.reviews.length > 0 && (
      <section class="section" style="background:var(--paper-2);padding:var(--section-y) 0" aria-label={`Omdömen från Reco om badrumsrenovering i ${content.city}`}>
        <div class="container">
          <span class="eyebrow section-label">Omdömen</span>
          <h2 class="h-section" style="margin-top:14px">Vad våra <em>kunder säger</em></h2>
          <p class="section-lead" style="margin-top:18px">Verifierade omdömen från <a href="https://www.reco.se/haga-plattsattning-ab-sollentuna" rel="external noopener" style="color:var(--ink);font-weight:600;border-bottom:1px solid var(--ink)">Reco</a> — totalt 4.9 av 5 baserat på 34 omdömen.</p>
          <div class="reviews-grid">
            {content.reviews.map((rev) => (
              <article class="review-card">
                <div class="review-stars" aria-label={`${rev.rating} av 5 stjärnor`}>
                  <span>{'★'.repeat(rev.rating)}</span><span class="empty">{'★'.repeat(5 - rev.rating)}</span>
                </div>
                <blockquote>{rev.text}</blockquote>
                <cite>— {rev.author}</cite>
                <p class="review-meta">{rev.date} · Källa: <a href="https://www.reco.se/haga-plattsattning-ab-sollentuna" rel="external noopener">Reco</a></p>
              </article>
            ))}
          </div>
          <div style="margin-top:40px">
            <RecoWidget />
          </div>
        </div>
      </section>
    )}

    <section class="s-faq" id="faq" aria-label={`Vanliga frågor om badrumsrenovering i ${content.city}`}>
      <div class="container">
        <div class="faq-grid">
          <div>
            <span class="eyebrow section-label">Vanliga frågor</span>
            <h2 class="h-section" style="margin-top:14px">{content.faqTitle}</h2>
            <p class="section-lead" style="margin-top:18px">{content.faqLead}</p>
            <a href="/offertforfragan/" class="btn btn-secondary" style="margin-top:24px">Fråga oss direkt <span class="arrow">→</span></a>
          </div>
          <div class="faq-list">
            {content.faqs.map((faq) => (
              <details class="faq-item">
                <summary>{faq.question}<span class="toggle">+</span></summary>
                <div class="answer faq-answer" set:html={faq.answerHtml} />
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section" aria-label={`Relaterade tjänster i ${content.city}`}>
      <div class="container" style="max-width:900px">
        <p class="section-lead" style="margin:0">
          {relatedLinksIntro} Jämför gärna vår
          <a href="/badrumsrenovering-stockholm/" style="color:var(--ink);font-weight:600;border-bottom:1px solid var(--ink)">badrumsrenovering i Stockholm</a>,
          våra tjänster för
          <a href="/kakelsattare-stockholm/" style="color:var(--ink);font-weight:600;border-bottom:1px solid var(--ink)">kakelsättare i Stockholm</a>
          och
          <a href="/koksrenovering-stockholm/" style="color:var(--ink);font-weight:600;border-bottom:1px solid var(--ink)">köksrenovering i Stockholm</a>.
          Du kan även
          <a href="/referensprojekt/" style="color:var(--ink);font-weight:600;border-bottom:1px solid var(--ink)">se våra referensprojekt</a>
          innan du
          <a href="/offertforfragan/" style="color:var(--ink);font-weight:600;border-bottom:1px solid var(--ink)">begär en kostnadsfri offert</a>.
        </p>
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(reviewJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

    <SiteFooter pageFocus={content.footerFocus} />

    <script type="application/ld+json" set:html={JSON.stringify(localBusinessJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
  </body>
</html>
