---
import SiteFooter from './SiteFooter.astro';
import SiteNav from './SiteNav.astro';
import type { BadrumsLocationContent } from '../data/badrumsLocations';
import { BUSINESS } from '../data/business';

export interface Props {
  content: BadrumsLocationContent;
}

const { content } = Astro.props;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Hem', item: 'https://www.hagaplattsattning.se/' },
    { '@type': 'ListItem', position: 2, name: 'Tjänster' },
    {
      '@type': 'ListItem',
      position: 3,
      name: `Badrumsrenovering ${content.city}`,
      item: `https://www.hagaplattsattning.se${content.route}`,
    },
  ],
};

const reviewJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Review',
    itemReviewed: { '@type': 'LocalBusiness', '@id': 'https://www.hagaplattsattning.se/#business', name: 'Haga Plattsättning AB' },
    reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person', name: 'Edit W' },
    datePublished: '2026-04-08',
    reviewBody:
      'Otroligt bra upplevelse, de visade stort engagemang i vart projekt redan fran start. Var bade foljsamma och flexibla med vara onskemal, men ocksa drivande och initiativtagande med egna forbattringar och losningar.',
    publisher: { '@type': 'Organization', name: 'Reco.se' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Review',
    itemReviewed: { '@type': 'LocalBusiness', '@id': 'https://www.hagaplattsattning.se/#business', name: 'Haga Plattsättning AB' },
    reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
    author: { '@type': 'Person', name: 'Adam K, VD Rikets Projektutveckling AB' },
    datePublished: '2025-11-08',
    reviewBody:
      'Vi pa Rikets Projektutveckling AB har anlitat Haga Plattsattning AB som underentreprenor vid flera tillfallen och kan varmt rekommendera dem.',
    publisher: { '@type': 'Organization', name: 'Reco.se' },
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};

const localBusinessJsonLd = {
  ...BUSINESS,
  description: content.localBusinessDescription,
  knowsAbout: [
    'Badrumsrenovering',
    `Badrumsrenovering ${content.city}`,
    'Kakelsättning',
    'Plattsättning',
    'Våtrum',
    'BKR-behörighet',
  ],
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${content.seo.canonical}#service`,
  name: `Badrumsrenovering ${content.city}`,
  serviceType: 'Badrumsrenovering',
  provider: { '@id': 'https://www.hagaplattsattning.se/#business' },
  areaServed: content.city,
  url: content.seo.canonical,
  potentialAction: {
    '@type': 'RequestQuoteAction',
    target: 'https://www.hagaplattsattning.se/offertforfragan/',
  },
};
---

<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/Hagaplattsattning.favicon.ico" sizes="any" />
    <link rel="icon" href="/Hagaplattsattning.favicon.svg" type="image/svg+xml" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow,max-image-preview:large" />

    <title>{content.seo.title}</title>
    <meta name="description" content={content.seo.description} />
    <link rel="canonical" href={content.seo.canonical} />
    <link rel="alternate" hreflang="sv-SE" href={content.seo.canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:site_name" content="Haga Plattsättning AB" />
    <meta property="og:url" content={content.seo.canonical} />
    <meta property="og:title" content={content.seo.ogTitle} />
    <meta property="og:description" content={content.seo.ogDescription} />
    <meta property="og:image" content={content.seo.ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={content.seo.ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.seo.twitterTitle} />
    <meta name="twitter:description" content={content.seo.twitterDescription} />
    <meta name="twitter:image" content={content.seo.twitterImage} />

    <meta name="geo.region" content="SE-AB" />
    <meta name="geo.placename" content={content.seo.geoPlacename} />
    <meta name="geo.position" content={content.seo.geoPosition} />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, -apple-system, sans-serif; }

      .section-inner { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
      .breadcrumb { max-width: 1200px; margin: 0 auto; padding: 1rem 1.5rem 0; font-size: 0.82rem; color: #888; }
      .breadcrumb a { color: #555; text-decoration: none; }
      .breadcrumb span { margin: 0 0.4rem; color: #ccc; }
      .hero {
        position: relative;
        min-height: min(78vh, 680px);
        overflow: hidden;
        border-bottom: 1px solid #e8e8ee;
        display: flex;
        align-items: center;
        padding-top: 84px;
      }
      .hero-media {
        position: absolute;
        inset: 0;
        z-index: 0;
      }
      .hero-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 38%;
        display: block;
      }
      .hero-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        background:
          linear-gradient(90deg, rgba(5, 6, 14, 0.7) 0%, rgba(5, 6, 14, 0.5) 34%, rgba(5, 6, 14, 0.2) 56%, rgba(5, 6, 14, 0.08) 100%),
          linear-gradient(180deg, rgba(0, 0, 0, 0.24) 0%, rgba(0, 0, 0, 0.16) 35%, rgba(0, 0, 0, 0.34) 100%);
      }
      .hero-inner {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 1320px;
        margin: 0 auto;
        padding: 0 1.5rem 3rem;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
      }
      .hero-text {
        font-family: Arial, Helvetica, sans-serif;
        color: #111111;
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        backdrop-filter: blur(3px);
        padding: clamp(1.6rem, 4vw, 2.2rem);
        max-width: 680px;
      }
      .hero h1 { font-size: clamp(1.6rem, 3vw, 2.7rem); font-weight: 700; color: #111111; line-height: 1.18; margin-bottom: 0.7rem; letter-spacing: -0.02em; }
      .hero h1 span { color: #111111; }
      .hero-lead { font-size: 0.94rem; color: #222222; line-height: 1.58; margin-bottom: 1.25rem; max-width: 560px; }
      .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
      .btn-primary { background: #111111; border: 1px solid #111111; color: #ffffff; font-weight: 700; font-size: 0.88rem; padding: 0.72rem 1.3rem; border-radius: 10px; text-decoration: none; }
      .btn-ghost { color: #111111; font-size: 0.88rem; font-weight: 500; text-decoration: none; }
      .bkr-section { background: #f8f8fb; border-top: 1px solid #e8e8ee; padding: 5rem 0; }
      .bkr-inner { max-width: 900px; margin: 0 auto; padding: 0 1.5rem; display: grid; grid-template-columns: 1fr; align-items: center; gap: 2rem; }
      .bkr-image {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0,0,0,0.1);
        line-height: 0;
      }
      .bkr-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        border-radius: 12px;
      }
      .bkr-text h2 { font-size: clamp(1.5rem, 2.8vw, 2rem); font-weight: 800; color: #0a0a1a; line-height: 1.2; margin-bottom: 1.1rem; }
      .bkr-text p { font-size: 0.95rem; color: #444; line-height: 1.75; margin-bottom: 1rem; }
      .section-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #888; margin-bottom: 0.6rem; }
      .guide-section { background: #fff; padding: 5rem 0; border-top: 1px solid #ececf2; }
      .guide-header { max-width: 880px; margin: 0 auto 3rem; padding: 0 1.5rem; text-align: left; color: #333; line-height: 1.75; font-size: 0.96rem; }
      .guide-header h2 { font-size: clamp(1.65rem, 2.9vw, 2.2rem); font-weight: 800; line-height: 1.2; margin-bottom: 1rem; color: #0a0a1a; }
      .guide-block { border-top: 1px solid #efeff3; padding: 3rem 0; }
      .guide-block.gray { background: #f8f8fb; }
      .guide-block-inner { max-width: 900px; margin: 0 auto; padding: 0 1.5rem; display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: start; }
      .guide-block-inner.text-only { grid-template-columns: 1fr; max-width: 900px; }
      .guide-text h3 { font-size: clamp(1.28rem, 2.2vw, 1.6rem); font-weight: 800; color: #0a0a1a; line-height: 1.25; margin-bottom: 0.9rem; }
      .guide-text p { font-size: 0.94rem; color: #444; line-height: 1.75; margin-bottom: 1rem; }
      .bkr-checklist { list-style: none; margin: 1.5rem 0 2rem; display: flex; flex-direction: column; gap: 0.65rem; }
      .bkr-checklist li { display: flex; align-items: flex-start; gap: 0.65rem; font-size: 0.92rem; color: #222; font-weight: 500; line-height: 1.5; }
      .bkr-checklist li::before { content: '✓'; color: #2a7a2a; font-weight: 700; font-size: 1rem; flex-shrink: 0; margin-top: 0.05rem; }
      .price-table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.88rem; }
      .price-table th, .price-table td { text-align: left; padding: 0.75rem 0.8rem; border-bottom: 1px solid #ececf2; }
      .price-table th { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.06em; color: #666; }
      .faq-section { background: #fff; border-top: 1px solid #e8e8ee; padding: 5rem 0; }
      .section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; color: #0a0a1a; margin-bottom: 0.75rem; }
      .section-lead { font-size: 1rem; color: #555; max-width: 660px; line-height: 1.7; margin-bottom: 3rem; }
      .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
      .faq-item { background: #fff; border-radius: 10px; overflow: hidden; box-shadow: 0 1px 6px rgba(0,0,0,0.05); }
      .faq-item summary { list-style: none; padding: 1.1rem 1.4rem; font-size: 0.92rem; font-weight: 700; color: #0a0a1a; cursor: pointer; }
      .faq-answer { padding: 0 1.4rem 1.2rem; font-size: 0.87rem; color: #555; line-height: 1.7; border-top: 1px solid #f0f0f5; }
      @media (max-width: 900px) {
        .hero {
          min-height: auto;
          padding-top: 72px;
        }
        .hero-media img {
          object-position: center;
        }
        .hero-inner {
          padding: 0 1rem 1.4rem;
          min-height: calc(100vh - 60px);
          align-items: end;
          flex-direction: column;
          justify-content: flex-end;
          gap: 1rem;
        }
        .hero-text {
          max-width: 100%;
          padding: 1.2rem;
          border-radius: 16px;
        }
        .hero h1 {
          font-size: clamp(1.35rem, 7vw, 2rem);
          margin-bottom: 0.55rem;
        }
        .hero-lead {
          font-size: 0.86rem;
          margin-bottom: 1rem;
        }
        .hero-actions {
          width: 100%;
          gap: 0.7rem;
        }
        .btn-primary,
        .btn-ghost {
          width: 100%;
          min-height: 48px;
          display: flex;
          align-items: center;
          justify-content: center;
          border-radius: 10px;
        }
        .btn-ghost {
          border: 1px solid rgba(0,0,0,0.22);
          background: rgba(255,255,255,0.8);
        }
        .bkr-inner, .guide-block-inner { grid-template-columns: 1fr; }
        .faq-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <SiteNav />

    <div class="breadcrumb" aria-label="Brödsmulor">
      <a href="/">Hem</a> <span>›</span>
      Tjänster <span>›</span>
      <strong>{`Badrumsrenovering ${content.city}`}</strong>
    </div>

    <section class="hero" aria-label={`Badrumsrenovering ${content.city} - Haga Plattsättning AB`}>
      <div class="hero-media">
        <img
          src={content.hero.imageSrc}
          alt={content.hero.imageAlt}
          width="2400"
          height="1350"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="hero-overlay"></div>
      <div class="hero-inner">
        <div class="hero-text">
          <h1>Badrumsrenovering <span>{`i ${content.city}`}</span></h1>
          <p class="hero-lead">{content.hero.lead}</p>
          <div class="hero-actions">
            <a href="/offertforfragan/" class="btn-primary">Få kostnadsfri offert →</a>
            <a href="#faq" class="btn-ghost">Vanliga frågor ↓</a>
          </div>
        </div>
      </div>
    </section>

    <section class="bkr-section" aria-label="BKR-behörighet och försäkringsskydd vid badrumsrenovering">
      <div class="bkr-inner">
        {content.bkrImageSrc && (
          <div class="bkr-image">
            <img
              src={content.bkrImageSrc}
              alt={content.bkrImageAlt ?? `BKR-behörig badrumsrenovering i ${content.city}`}
              width="580"
              height="480"
              loading="lazy"
            />
          </div>
        )}
        <div class="bkr-text">
          <p class="section-label">Trygghet och försäkring</p>
          <h2>Vad händer om du renoverar badrummet utan kvalitetsdokument?</h2>
          <p>En felaktig våtrumslösning kan bli kostsam. Med dokumenterad BKR-process minskar du risken för ersättningstvist vid skada och får ett badrum som är byggt för lång livslängd.</p>
          <ul class="bkr-checklist" aria-label="Vad BKR-behörighet ger dig">
            <li>Kvalitetsdokument som krävs av försäkringsbolag</li>
            <li>Tätskikt enligt gällande branschregler och BBV</li>
            <li>Dokumenterad egenkontroll under hela projektet</li>
            <li>Tydlig slutleverans som är enkel att spara till framtida försäljning</li>
          </ul>
          <a href="/offertforfragan/" class="btn-primary">Boka kostnadsfri offert →</a>
        </div>
      </div>
    </section>

    <section class="guide-section" aria-label={`Komplett guide till badrumsrenovering i ${content.city}`}>
      <div class="guide-header">
        <p class="section-label">{`Guide: Badrumsrenovering ${content.city}`}</p>
        <h2>{content.guideHeader.title}</h2>
        <p set:html={content.guideHeader.introHtml} />
      </div>

      {content.guideBlocks.map((block) => (
        <div class:list={['guide-block', block.gray && 'gray']}>
          <div class:list={['guide-block-inner', block.textOnly && 'text-only']}>
            <div class="guide-text">
              <h3>{block.title}</h3>
              <div set:html={block.bodyHtml} />
            </div>
          </div>
        </div>
      ))}
    </section>

    <section class="faq-section" id="faq" aria-label={`Vanliga frågor om badrumsrenovering i ${content.city}`}>
      <div class="section-inner">
        <p class="section-label">Vanliga frågor</p>
        <h2 class="section-title">{content.faqTitle}</h2>
        <p class="section-lead">{content.faqLead}</p>
        <div class="faq-grid">
          {content.faqs.map((faq) => (
            <details class="faq-item">
              <summary>{faq.question}</summary>
              <div class="faq-answer" set:html={faq.answerHtml} />
            </details>
          ))}
        </div>
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(reviewJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

    <SiteFooter pageFocus={content.footerFocus} />

    <script type="application/ld+json" set:html={JSON.stringify(localBusinessJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
  </body>
</html>
