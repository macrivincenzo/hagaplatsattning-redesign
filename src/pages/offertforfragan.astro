---
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
---

<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/Hagaplattsattning.favicon.ico" sizes="any" />
    <link rel="icon" href="/Hagaplattsattning.favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow,max-image-preview:large" />

    <title>Offertförfrågan – Haga Plattsättning AB</title>
    <meta
      name="description"
      content="Skicka offertförfrågan till Haga Plattsättning AB. Beskriv ditt projekt och få återkoppling om badrumsrenovering, kakelsättning eller köksrenovering i Stockholm."
    />
    <link rel="canonical" href="https://www.hagaplattsattning.se/offertforfragan/" />
    <link rel="alternate" hreflang="sv-SE" href="https://www.hagaplattsattning.se/offertforfragan/" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="sv_SE" />
    <meta property="og:site_name" content="Haga Plattsättning AB" />
    <meta property="og:url" content="https://www.hagaplattsattning.se/offertforfragan/" />
    <meta property="og:title" content="Offertförfrågan – Haga Plattsättning AB" />
    <meta property="og:description" content="Få en tydlig offert för badrum, kök eller kakelsättning i Stockholm." />
    <meta property="og:image" content="https://www.hagaplattsattning.se/hagaplatt_18.avif" />

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Hem", "item": "https://www.hagaplattsattning.se/" },
        { "@type": "ListItem", "position": 2, "name": "Offertförfrågan", "item": "https://www.hagaplattsattning.se/offertforfragan/" }
      ]
    }
    </script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "@id": "https://www.hagaplattsattning.se/offertforfragan/",
      "url": "https://www.hagaplattsattning.se/offertforfragan/",
      "pageType": "ContactPage",
      "name": "Offertförfrågan – Haga Plattsättning AB",
      "description": "Skicka offertförfrågan till Haga Plattsättning AB för badrumsrenovering, kakelsättning eller köksrenovering i Stockholm.",
      "inLanguage": "sv-SE",
      "isPartOf": { "@id": "https://www.hagaplattsattning.se/#website" },
      "mainEntity": { "@id": "https://www.hagaplattsattning.se/#business" }
    }
    </script>
  </head>
  <body>
    <SiteNav />

    <div class="page-header">
      <nav class="breadcrumb" aria-label="Brödsmulor">
        <a href="/">Hem</a> <span>›</span>
        <strong style="color:var(--ink)">Offertförfrågan</strong>
      </nav>
    </div>

    <section class="section" aria-label="Offertförfrågan">
      <div class="container">
        <div style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start" class="offer-grid">
          <div>
            <span class="eyebrow section-label">Offertförfrågan</span>
            <h1 class="h-display" style="margin-top:14px;font-size:clamp(36px,4.4vw,56px)">Få en tydlig offert <em>för ditt projekt</em></h1>
            <p class="lede" style="margin-top:22px">
              Beskriv kort vad du behöver hjälp med så återkommer vi med förslag på upplägg
              och preliminär tidsplan. Vi hjälper dig med badrumsrenovering,
              kakelsättning och köksrenovering i Stockholm.
            </p>
            <div style="display:flex;flex-direction:column;gap:12px;margin-top:24px">
              <a href="tel:0739133348" style="display:inline-flex;align-items:center;gap:8px;color:var(--ink);font-weight:600;font-size:17px">📞 073-913 33 48</a>
              <a href="mailto:kontakt@hagaplattsattning.se" style="display:inline-flex;align-items:center;gap:8px;color:var(--ink);font-weight:600;font-size:17px">✉ kontakt@hagaplattsattning.se</a>
            </div>
            <ul class="bkr-checklist" style="margin-top:28px">
              <li>BKR-behöriga plattsättare</li>
              <li>Tydlig process från offert till slutbesiktning</li>
              <li>Våtrumsintyg vid badrumsprojekt</li>
              <li>Återkoppling normalt inom 24 timmar på vardagar</li>
            </ul>
          </div>

          <div class="offert-form">
            <form action="mailto:kontakt@hagaplattsattning.se" method="post" enctype="text/plain" style="display:grid;gap:18px">
              <div class="row">
                <label for="name">Namn
                  <input id="name" name="name" type="text" required />
                </label>
                <label for="phone">Telefon
                  <input id="phone" name="phone" type="tel" required />
                </label>
              </div>
              <label for="email">E-post
                <input id="email" name="email" type="email" required />
              </label>
              <label for="project">Typ av projekt
                <input id="project" name="project" type="text" placeholder="Ex. badrumsrenovering i BRF" />
              </label>
              <label for="message">Beskrivning
                <textarea id="message" name="message" placeholder="Yta, ort, önskad start och annan relevant info"></textarea>
              </label>
              <div class="submit">
                <button class="btn btn-primary" type="submit" style="width:100%;justify-content:center">Skicka offertförfrågan <span class="arrow">→</span></button>
              </div>
              <p style="font-size:12.5px;color:var(--ink-mute);font-family:var(--mono);letter-spacing:0.04em">Vi återkopplar normalt inom 24 timmar på vardagar.</p>
            </form>
          </div>
        </div>
      </div>
    </section>

    <style>
      @media (max-width:880px){
        .offer-grid{grid-template-columns:1fr!important}
      }
    </style>

    <SiteFooter pageFocus="På offertförfrågan samlar vi snabbaste vägen till kontakt så att du enkelt kan få rätt upplägg för ditt projekt i Stockholm." />
  </body>
</html>
