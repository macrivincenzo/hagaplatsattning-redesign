        { "@type": "Question", "name": "Vad kostar en kakelsättare i Stockholm per timme?", "acceptedAnswer": { "@type": "Answer", "text": "Timpriser för kakelsättare i Stockholm ligger på 650–900 kr/timme före ROT-avdrag. Med ROT på 50 % (2024–2026) blir kostnaden 325–450 kr/timme." } },
        { "@type": "Question", "name": "Vad är skillnaden mellan en kakelsättare och en plattsättare?", "acceptedAnswer": { "@type": "Answer", "text": "Det finns ingen skillnad – kakelsättare och plattsättare är samma yrke. Båda utför montering av kakel, klinker, mosaik och natursten." } },
        { "@type": "Question", "name": "Hur vet jag om en kakelsättare är BKR-behörig?", "acceptedAnswer": { "@type": "Answer", "text": "Be om kakelsättarens BKR-behörighetsnummer och kontrollera det på bkr.se. Alla behöriga företag finns i Byggkeramikrådets offentliga register." } },
        { "@type": "Question", "name": "Behöver kakelsättaren samarbeta med en VVS-firma?", "acceptedAnswer": { "@type": "Answer", "text": "Ja, vid arbeten som berör vattenledningar, avlopp eller golvbrunnar krävs en Säker Vatten-auktoriserad VVS-installatör. En kakelsättare får inte utföra rörarbete." } },
        { "@type": "Question", "name": "Hur lång tid tar det att kakla ett badrum?", "acceptedAnswer": { "@type": "Answer", "text": "Enbart kakelsättningen tar normalt 3–5 arbetsdagar för ett standardbadrum på 5–8 kvm. Med storformat eller komplicerade mönster kan det ta upp till 7 dagar." } },
        { "@type": "Question", "name": "Kan en kakelsättare hjälpa mig välja kakel?", "acceptedAnswer": { "@type": "Answer", "text": "Ja, en erfaren kakelsättare kan rekommendera material baserat på utrymme, budget och önskad stil – från formatval och färgsättning till fog och ytbehandling." } },
