const localBusinessJsonLd = {
  ...BUSINESS,
  description:
    'BKR-behörig plattsättare i Stockholm. Vi gör fuktmätning och statusbedömning av badrum — när det är dags att renovera, vad teknisk livslängd innebär, och hur en statusbesiktning fungerar.',
