<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/logo.avif" type="image/avif" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Professionell badrumsrenovering i Stockholm. Vi sätter kakel och klinker med hög kvalitet och fast pris. Certifierade plattsättare med våtrumsintyg. Få gratis offert idag." />
    <title>Haga Plattsättning AB – Badrumsrenovering &amp; Kakelsättning Stockholm</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, -apple-system, sans-serif; }

      /* ── RECO WIDGET ── */
      .reco-bar { width: 100%; overflow: hidden; }
      .reco-bar iframe { width: 100%; border: 0; display: block; overflow: hidden; height: 225px; }

      /* ── CONTACT BAR ── */
      .contact-bar {
        background: #12122a;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3rem;
        height: 44px;
        font-size: 0.88rem;
      }
      .contact-bar a {
        color: rgba(255,255,255,0.85);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        transition: color 0.15s;
      }
      .contact-bar a:hover { color: #fff; }
      @media (max-width: 500px) {
        .contact-bar { justify-content: space-around; gap: 0; }
      }

      /* ── NAVIGATION ── */
      .site-nav {
        background: #000000;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 2px 12px rgba(0,0,0,0.5);
      }
      .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 72px;
        gap: 1.5rem;
      }

      /* Logo + badges */
      .nav-brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-shrink: 0;
        text-decoration: none;
      }
      .nav-logo {
        height: 48px;
        width: auto;
        display: block;
      }
      .nav-badges {
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .nav-badges > div {
        display: flex;
        align-items: center;
        width: 52px;
        height: 52px;
        flex-shrink: 0;
      }
      .nav-badges > div img,
      .nav-badges > div a,
      .nav-badges > div svg { width: 52px !important; height: 52px !important; }

      /* Links */
      .nav-links {
        display: flex;
        align-items: center;
        list-style: none;
        gap: 0.1rem;
        flex: 1;
        justify-content: center;
      }
      .nav-links a {
        color: #ffffff;
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 500;
        padding: 0.5rem 0.8rem;
        border-radius: 5px;
        transition: color 0.15s, background 0.15s;
        white-space: nowrap;
      }
      .nav-links a:hover { color: #fff; background: rgba(255,255,255,0.07); }

      /* Dropdown */
      .nav-dropdown { position: relative; }
      .nav-dropdown > a::after { content: ' ▾'; font-size: 0.7rem; opacity: 0.6; }
      .dropdown-menu {
        display: none;
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        background: #000000;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        padding: 0.5rem 0;
        min-width: 230px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.4);
        z-index: 200;
      }
      .nav-dropdown:hover .dropdown-menu { display: block; }
      .dropdown-menu a {
        display: block;
        color: #ffffff !important;
        font-size: 0.87rem !important;
        padding: 0.6rem 1.2rem !important;
        border-radius: 0 !important;
        background: none !important;
        white-space: nowrap;
      }
      .dropdown-menu a:hover { color: #fff !important; background: rgba(255,255,255,0.07) !important; }

      /* CTA button */
      .nav-cta {
        flex-shrink: 0;
        background: #fff;
        color: #1a1a2e !important;
        font-weight: 700 !important;
        font-size: 0.88rem !important;
        padding: 0.5rem 1.2rem !important;
        border-radius: 6px !important;
        transition: opacity 0.15s !important;
        white-space: nowrap;
      }
      .nav-cta:hover { opacity: 0.88 !important; background: #fff !important; }

      /* Hamburger */
      .nav-hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        background: none;
        border: none;
        padding: 4px;
      }
      .nav-hamburger span {
        display: block;
        width: 24px;
        height: 2px;
        background: #fff;
        border-radius: 2px;
        transition: 0.25s;
      }

      /* Mobile menu */
      .nav-mobile {
        display: none;
        flex-direction: column;
        background: #000000;
        border-top: 1px solid rgba(255,255,255,0.08);
        padding: 1rem 1.5rem 1.5rem;
        gap: 0.25rem;
      }
      .nav-mobile.open { display: flex; }
      .nav-mobile a {
        color: rgba(255,255,255,0.85);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        padding: 0.65rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        transition: color 0.15s;
      }
      .nav-mobile a:hover { color: #fff; }
      .nav-mobile .mobile-section {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255,255,255,0.35);
        padding: 0.75rem 0 0.25rem;
      }
      .nav-mobile .mobile-cta {
        margin-top: 0.75rem;
        background: #fff;
        color: #1a1a2e !important;
        font-weight: 700 !important;
        text-align: center;
        padding: 0.75rem !important;
        border-radius: 6px;
        border-bottom: none !important;
      }

      @media (max-width: 900px) {
        .nav-links, .nav-cta { display: none; }
        .nav-hamburger { display: flex; }
        .nav-badges { display: none; }
      }
    </style>
  </head>
  <body>

    <!-- ── RECO WIDGET ── -->
    <div class="reco-bar">
      <iframe
        src="https://widget.reco.se/v2/venues/4532782/horizontal/xlarge?inverted=false&border=false&lang=sv"
        title="Haga Plattsättning AB - Omdömen på Reco"
        height="225"
        style="width:100%;border:0;display:block;overflow:hidden;"
        data-reactroot
      ></iframe>
    </div>

    <!-- ── CONTACT BAR ── -->
    <div class="contact-bar">
      <a href="tel:0739133348" aria-label="Ring oss">📞 073-913 33 48</a>
      <a href="mailto:kontakt@hagaplattsattning.se" aria-label="Skicka e-post">✉ kontakt@hagaplattsattning.se</a>
    </div>

    <!-- ── NAVIGATION ── -->
    <nav class="site-nav" aria-label="Huvudnavigation">
      <div class="nav-inner">

        <!-- Logo + Reco badges -->
        <a href="/" class="nav-brand" aria-label="Haga Plattsättning AB – startsida">
          <img src="/logo.avif" alt="Haga Plattsättning AB" class="nav-logo" width="120" height="48" />
          <div class="nav-badges">
            <div id="reco--badge-yearsInRowBadge"></div>
            <div id="reco--badge-2025"></div>
            <div id="reco--badge-2024"></div>
          </div>
        </a>

        <!-- Desktop links -->
        <ul class="nav-links" role="list">
          <li><a href="/">Hem</a></li>
          <li><a href="/om-oss">Om oss</a></li>
          <li class="nav-dropdown">
            <a href="#tjanster" aria-haspopup="true">Tjänster</a>
            <div class="dropdown-menu" role="menu">
              <a href="/badrumsrenovering-stockholm" role="menuitem">Badrumsrenovering Stockholm</a>
              <a href="/badrumsrenovering-pris" role="menuitem">Badrumsrenovering Pris</a>
              <a href="/kakelsattare-stockholm" role="menuitem">Kakelsättare Stockholm</a>
              <a href="/koksrenovering-stockholm" role="menuitem">Köksrenovering Stockholm</a>
            </div>
          </li>
          <li><a href="/referensprojekt">Referensprojekt</a></li>
          <li><a href="/offertforfragan">Offertförfrågan</a></li>
        </ul>

        <!-- Desktop CTA -->
        <a href="/offertforfragan" class="nav-cta" aria-label="Få gratis offert">Få offert</a>

        <!-- Hamburger -->
        <button class="nav-hamburger" aria-label="Öppna meny" aria-expanded="false" id="hamburger">
          <span></span><span></span><span></span>
        </button>

      </div>

      <!-- Mobile menu -->
      <div class="nav-mobile" id="mobile-menu" role="navigation" aria-label="Mobilmeny">
        <a href="/">Hem</a>
        <a href="/om-oss">Om oss</a>
        <span class="mobile-section">Tjänster</span>
        <a href="/badrumsrenovering-stockholm">Badrumsrenovering Stockholm</a>
        <a href="/badrumsrenovering-pris">Badrumsrenovering Pris</a>
        <a href="/kakelsattare-stockholm">Kakelsättare Stockholm</a>
        <a href="/koksrenovering-stockholm">Köksrenovering Stockholm</a>
        <a href="/referensprojekt">Referensprojekt</a>
        <a href="/offertforfragan">Offertförfrågan</a>
        <a href="/offertforfragan" class="mobile-cta">Få gratis offert</a>
      </div>
    </nav>

    <!-- Reco badge scripts -->
    <script src="https://widget.reco.se/yearsInRowBadge/4532782.js"></script>
    <script src="https://widget.reco.se/badge/2025/4532782.js"></script>
    <script src="https://widget.reco.se/badge/2024/4532782.js"></script>

    <!-- Hamburger toggle -->
    <script>
      const btn = document.getElementById('hamburger');
      const menu = document.getElementById('mobile-menu');
      btn.addEventListener('click', () => {
        const open = menu.classList.toggle('open');
        btn.setAttribute('aria-expanded', open);
      });
    </script>

  </body>
</html>
