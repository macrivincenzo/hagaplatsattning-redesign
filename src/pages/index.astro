    <!-- ── RECO XL WIDGET ── -->
    <section class="section" style="padding:0 0 var(--section-y)" aria-label="Reco-omdömen">
      <div class="container">
        <iframe
          src="https://widget.reco.se/v2/venues/4532782/horizontal/xlarge?inverted=false&border=true&lang=sv"
          title="Haga Plattsättning AB - Omdömen på Reco"
          height="225"
