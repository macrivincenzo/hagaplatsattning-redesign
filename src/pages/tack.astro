---
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
---

<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/Hagaplattsattning.favicon.ico" sizes="any" />
    <link rel="icon" href="/Hagaplattsattning.favicon.svg" type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow,max-image-preview:large" />

    <title>Tack for din forfragan - Haga Plattsattning AB</title>
    <meta
      name="description"
      content="Tack for din offertforfragan. Vi kommer att kontakta er sa fort vi kan."
    />
    <link rel="canonical" href="https://www.hagaplattsattning.se/tack/" />
    <link rel="alternate" hreflang="sv-SE" href="https://www.hagaplattsattning.se/tack/" />
  </head>
  <body>
    <SiteNav />

    <div class="page-header">
      <nav class="breadcrumb" aria-label="Brodsmulor">
        <a href="/">Hem</a> <span>›</span>
        <strong style="color:var(--ink)">Tack</strong>
      </nav>
    </div>

    <section class="section" aria-label="Tack for din forfragan">
      <div class="container" style="max-width:900px">
        <span class="eyebrow section-label">Tack</span>
        <h1 class="h-display" style="margin-top:14px;font-size:clamp(34px,4.6vw,56px)">
          Vi har tagit emot din <em>forfragan</em>
        </h1>
        <p class="lede" style="margin-top:22px;max-width:60ch">
          Tack for ditt meddelande. Vi kommer att kontakta er sa fort vi kan, vanligtvis inom 24 timmar pa vardagar.
        </p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:28px">
          <a href="/" class="btn btn-secondary">Till startsidan <span class="arrow">→</span></a>
          <a href="/offertforfragan/" class="btn btn-primary">Skicka en ny forfragan <span class="arrow">→</span></a>
        </div>
      </div>
    </section>

    <SiteFooter pageFocus="Tacksidan bekräftar mottagen offertförfrågan och visar nästa steg för snabb återkoppling." />
  </body>
</html>
