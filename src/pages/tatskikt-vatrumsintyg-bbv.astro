  audience: { '@type': 'Audience', audienceType: 'Bostadsägare, BRF-styrelser, mäklare i Stockholm' },
  proficiencyLevel: 'Beginner',
  mainEntityOfPage: 'https://www.hagaplattsattning.se/tatskikt-vatrumsintyg-bbv/',
