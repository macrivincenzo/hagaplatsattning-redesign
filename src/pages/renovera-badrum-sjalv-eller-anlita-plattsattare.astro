const PUBLISHED = '2026-05-11';
const UPDATED = '2026-05-11';

const localBusinessJsonLd = {
  ...BUSINESS,
  description:
    'BKR-behörig plattsättare i Stockholm. Vi förklarar vad du får göra själv i badrumsrenovering — och vad som kräver behörig firma för att intyg, försäkring och ROT-avdrag ska gälla.',
  knowsAbout: [
    'Renovera badrum själv',
    'Kakla badrum själv',
    'Tätskikt själv',
    'BKR-behörighet',
    'Säker Vatten',
    'ROT-avdrag',
    'Försäkring badrumsrenovering',
    'Badrumsrenovering Stockholm',
  ],
};

const faqs = [
  {
    q: 'Får man renovera badrummet själv?',
    a: 'Ja, men med viktiga begränsningar. Det är tillåtet att riva, demontera och utföra rent kosmetiskt arbete själv. Däremot är el- och gasinstallationer förbjudna i lag att utföra själv (källa: Säker Vatten). Och tätskikt, kakelsättning och VVS-arbete bör utföras av en BKR-behörig respektive Säker Vatten-auktoriserad firma — annars kan du inte få ett giltigt våtrumsintyg, vilket i sin tur påverkar försäkring och försäljning av bostaden.',
  },
  {
    q: 'Vilka moment får jag göra själv, och vilka kräver behörig?',
    a: 'Som privatperson får du göra rivning, demontering, städning, materialinköp och slutstädning. Du får inte göra elinstallationer eller gasinstallationer (lagförbud). Tätskikt och plattsättning är inte lagförbjudet men kräver BKR-behörighet för att intyg ska vara giltigt. VVS-arbete (stamming, blandare, golvbrunn) kräver Säker Vatten-auktoriserad firma för att uppfylla försäkringsbolagens krav.',
  },
  {
    q: 'Får man göra tätskikt själv i badrum?',
    a: 'Det finns ingen lag som förbjuder det, men det får praktiska konsekvenser. Endast en BKR-behörig kan utfärda ett giltigt våtrumsintyg enligt BBV (Branschregler för Våtrum). Utan intyg kan en framtida vattenskada avvisas av försäkringsbolaget, och bostadsrättsföreningen kan vägra godkänna renoveringen. Säker Vatten skriver: "Försäkringsbolagen har i regel fört in krav i sina försäkringsvillkor på utförande enligt etablerade branschregler."',
  },
  {
    q: 'Får man lägga kakel och klinker i badrum själv?',
    a: 'Att lägga kakel och klinker själv är inte olagligt. Problemet är inte plattsättningen i sig — utan att hela tätskikts- och dokumentationskedjan bryts. Om du lägger kakel på ett tätskikt som inte är monterat av BKR-behörig, eller utan korrekt egenkontroll, blir det svårt att få ett giltigt våtrumsintyg. Det påverkar både försäkring vid framtida skada och bostadens värde vid försäljning.',
  },
  {
    q: 'Är det enkelt att kakla själv?',
    a: 'Tekniskt: nej. En BKR-behörig plattsättare har genomgått utbildning i BBV och har erfarenhet av underlagsbedömning, fallbyggnad mot brunn, hörnlösningar och fogteknik. De vanligaste misstagen vid hemmarenovering är fel fall mot brunn (vatten samlas), otäta genomföringar (vatten rinner bakom kakel), bommad plattsättning (släpper efter 1–3 år) och felaktig silikonfogning. Var och en av dessa kan leda till fuktskada som visar sig först efter flera år.',
  },
  {
    q: 'Vad är det värsta som kan hända om jag gör fel?',
    a: 'Det värsta scenariot är en vattenskada som upptäcks år efter renoveringen. Eftersom arbetet inte är dokumenterat enligt BBV avvisas skadan av försäkringsbolaget. Du står själv för hela kostnaden — som vid en omfattande vattenskada kan bli flera hundra tusen kronor när bjälklag, väggar och eventuellt grannars utrymmen ska saneras. Detta är inte hypotetiskt; det är så försäkringsvillkoren faktiskt fungerar enligt Säker Vatten.',
  },
  {
    q: 'Vad händer med försäkringen om arbetet inte är fackmässigt?',
    a: 'Försäkringsbolagen har överlag fört in krav i försäkringsvillkoren på att våtrumsarbete ska vara utfört enligt etablerade branschregler (BBV eller GVK). Saknas våtrumsintyg eller är arbetet bevisligen inte fackmässigt utfört kan: skadan avvisas helt, självrisken höjas avsevärt, eller ersättningen sänkas med betydligt mer än självrisken. Exakta villkor skiljer sig mellan bolag — kontrollera ditt försäkringsbrev.',
  },
  {
    q: 'Kan man kakla över gammalt kakel?',
    a: 'Det är tekniskt möjligt om underlaget bedöms hållfast och tätskiktet är intakt — men i praktiken är det sällan en bra idé. Du tappar möjligheten att inspektera tätskiktet, badrummet blir mindre, fogen blir hög mot golv och dusch, och du får ingen ny garanti på det underliggande tätskiktet. Vid en eventuell skada är ansvarsfrågan komplicerad: är felet i det gamla eller nya skiktet? För att få ett nytt våtrumsintyg som täcker hela konstruktionen krävs i regel att man tar bort gammalt kakel och bygger upp tätskiktet på nytt.',
  },
  {
    q: 'Kan jag göra delar själv och anlita plattsättare för resten?',
    a: 'Ja, och det är ofta en bra balans. Vanligast är att kunden gör rivning, demontering, städning och materialinköp själv, och vi går in på de moment som kräver behörighet: tätskikt, kakelsättning, fogning och dokumentation. VVS-arbete koordineras med en Säker Vatten-auktoriserad firma som vi samarbetar med. Det viktiga är att momenten som kräver behörighet faktiskt utförs av behörig — då blir intyget giltigt även om du själv gjort förarbetet.',
  },
  {
    q: 'Hur räknar man rätt — har ROT-avdraget med detta att göra?',
    a: 'Ja, och det är ofta en faktor folk missar. ROT-avdraget 2026 ger 30 % skattereduktion på arbetskostnaden (max 50 000 kr per person och år) — men endast om arbetet utförs av en firma med F-skatt. Eget arbete ger inget ROT-avdrag alls. När du jämför kostnaden för att "spara pengar" på att göra själv vs. anlita firma, glöm inte att 30 % av arbetskostnaden hos en seriös plattsättare i praktiken bekostas av Skatteverket — inte av dig.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
