  datePublished: PUBLISHED,
  dateModified: UPDATED,
  inLanguage: 'sv-SE',
  about: [
    'Renovera badrum själv',
    'Kakla badrum själv',
    'Tätskikt själv',
    'BKR-behörighet',
    'Säker Vatten',
    'ROT-avdrag 2026',
    'Försäkring vattenskada',
  ],
  audience: {
    '@type': 'Audience',
    audienceType: 'Bostadsägare i Stockholm som överväger badrumsrenovering',
  },
  proficiencyLevel: 'Beginner',
  citation: [
    { '@type': 'CreativeWork', name: 'Branschregler för Våtrum (BBV)', url: 'https://www.bkr.se/regler' },
    { '@type': 'CreativeWork', name: 'Säker Vatten — Bygga rätt för konsumenter', url: 'https://sakervatten.se/bygga-ratt/konsumenter/' },
    { '@type': 'CreativeWork', name: 'Skatteverket — ROT-avdrag', url: 'https://www.skatteverket.se/privat/skatter/fastigheterochbostad/rotochrutarbete.4.7459477810df5bccdd4800018482.html' },
  ],
  mainEntityOfPage:
    'https://www.hagaplattsattning.se/renovera-badrum-sjalv-eller-anlita-plattsattare/',
