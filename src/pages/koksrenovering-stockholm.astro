        { "@type": "Question", "name": "Vilken typ av klinker passar bäst som köksgolv?", "acceptedAnswer": { "@type": "Answer", "text": "Vi rekommenderar klinker med halkklassificering R10 eller högre i matt eller halvmatt utförande. Storformat (60×60 cm) ger ett modernt intryck med färre fogar." } },
        { "@type": "Question", "name": "Kan ni lägga klinker direkt på befintligt köksgolv?", "acceptedAnswer": { "@type": "Answer", "text": "I vissa fall kan vi lägga klinker ovanpå befintligt golv om underlaget är stabilt och plant. Det höjer golvnivån med 10–15 mm, vilket kan påverka dörröppningar." } },
        { "@type": "Question", "name": "Måste jag anmäla köksrenoveringen till min BRF?", "acceptedAnswer": { "@type": "Answer", "text": "Om renoveringen berör vatten, avlopp eller bärande konstruktion ska du anmäla det. Enbart kakelbyte kräver normalt ingen anmälan – kontrollera med din förening." } },
        { "@type": "Question", "name": "Samarbetar ni med köksmontörer och snickare?", "acceptedAnswer": { "@type": "Answer", "text": "Ja, vi har ett nätverk av köksmontörer, snickare och elektriker i Stockholm som vi samarbetar med regelbundet." } }
      ]
    }
