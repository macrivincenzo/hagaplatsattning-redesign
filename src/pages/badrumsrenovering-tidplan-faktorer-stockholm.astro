const PUBLISHED = '2026-05-11';
const UPDATED = '2026-05-11';

const localBusinessJsonLd = {
  ...BUSINESS,
  description:
    'BKR-behörig plattsättare i Stockholm. Vi förklarar vilka faktorer som påverkar tidsåtgången för en badrumsrenovering — utan att lova en specifik tidplan, eftersom varje projekt är unikt. Skicka offertförfrågan för en konkret tidsuppskattning.',
  knowsAbout: [
    'Badrumsrenovering tidplan faktorer',
    'Tätskikt härdningstid',
    'BBV branschregler',
    'BRF bullertider Stockholm',
    'Faser i badrumsrenovering',
    'Förseningar renovering',
  ],
};

const faqs = [
  {
    q: 'Vilka är de viktigaste faktorerna som påverkar tidsåtgången?',
    a: 'Sex huvudfaktorer styr tidsåtgången: badrummets storlek, omfattning av rivning och underlagsarbete, VVS-omfattning (flytt av rör eller golvbrunn), tätskiktets härdningstid (icke förhandlingsbar enligt tillverkaranvisningar och BBV), BRF-krav på bullertider och tillgänglighet, samt eventuella fynd vid rivning. Av dessa är tätskiktets härdningstid det enda som är fast — resten varierar mellan projekt. Det är därför ingen seriös plattsättare lovar en exakt tidplan utan att först se badrummet.',
  },
  {
    q: 'Vad är tätskiktets härdningstid och varför kan den inte hoppas över?',
    a: 'Tätskiktet är det vattentäta lagret bakom kaklet. För att fungera måste det härda enligt tillverkarens specifikationer — typiskt mellan strykningar och innan kakelsättning får påbörjas. Dessa tider står på produktbladet och varierar mellan system (folie- eller smörjbart tätskikt), temperatur och luftfuktighet. Att skynda på detta moment är inte förhandlingsbart enligt BBV (Branschregler för Våtrum) — det är fysiskt nödvändigt för att skiktet ska bli vattentätt. Plattsättare som lovar en snabb renovering hoppar i regel över detta moment — och därmed bryter de mot BBV och försäkringsvillkoren.',
  },
  {
    q: 'Vilka faser ingår i en typisk renovering och vilka är tidskritiska?',
    a: 'En typisk renovering har sju faser: (1) Förberedelse och etablering, (2) rivning av befintligt material, (3) underlagsarbete och VVS-anslutningar, (4) tätskikt med härdningstid, (5) plattsättning, (6) fogning och silikonering, (7) städning och slutdokumentation. Av dessa är fas 4 (tätskiktets härdning) den enda som är tidsfast — den måste få sin tid oavsett hur snabbt plattsättaren arbetar. Faserna 1, 2, 5 och 6 kan effektiviseras med erfaren personal; fas 3 (underlagsarbete och VVS) varierar mest beroende på vad rivningen avslöjar.',
  },
  {
    q: 'Hur påverkar badrummets storlek och format tidsåtgången?',
    a: 'Storleken påverkar både rivnings- och plattsättningstiden, men inte linjärt. Ett mindre badrum är trångare att jobba i, har fler hörnskärningar per kvadratmeter och har mindre marginaler — vilket gör arbetet långsammare per yta. Ett medelstort badrum är vanligen mest tidseffektivt per kvadratmeter. Format på plattorna är också viktigt: storformat (60×60 cm och uppåt) tar längre tid per platta (transport, kapning, precision) men har färre fogar. Standardformat (15×15, 30×30) går snabbare per platta men kräver fler skärningar.',
  },
  {
    q: 'Hur påverkar VVS-arbete tidplanen?',
    a: 'VVS är ofta den största variabeln i tidplanen. Ett projekt utan rörflyttningar är förutsägbart: VVS-firman kommer in en dag för demontering och en dag för slutmontering. Vid flytt av rör (blandare, golvbrunn, toalett) krävs ny rördragning, vilket kan kräva flera arbetsmoment som måste passas in i sekvensen mellan rivning och tätskikt. I BRF kräver dessutom alla rörändringar styrelsens tillstånd — vilket är en separat administrativ tidsfaktor som måste ligga klart innan projektet startar.',
  },
  {
    q: 'Hur påverkar BRF-krav, tillstånd och bullertider tidplanen?',
    a: 'BRF-faktorer är ofta underskattade. Styrelsens tillstånd kan ta upp till en månad enligt Bostadsrätterna. Bullertider styr hur många effektiva arbetstimmar per kalendervecka som finns — en BRF som tillåter vardagar 07–17 men inga lördagar ger ungefär 50 effektiva arbetstimmar/vecka, medan en BRF som även tillåter lördagar 09–15 ger nästan 60. Skillnaden över ett 2–3 veckors projekt kan vara en hel kalendervecka. Granninformation, container­hantering och förvaltarkrav är fast administration som måste ligga klart innan start.',
  },
  {
    q: 'Varför kan en plattsättare inte ge en exakt tidplan i förväg?',
    a: 'För att det är fysiskt och praktiskt omöjligt att veta innan rivningen. Underlagets exakta skick, VVS-systemets faktiska kondition, eventuella fuktskador eller asbest, och oväntade fastighetsspecifika problem är alla okända fram till första rivningsdagen. En seriös plattsättare ger en "uppskattad tidplan" baserat på platsbesöket — och kommunicerar tydligt vad som kan röra tidplanen åt båda håll. En plattsättare som lovar en exakt tidplan innan rivning gissar — och det är där missnöjda kunder uppstår.',
  },
  {
    q: 'Vad är de vanligaste orsakerna till att projekt drar ut på tiden?',
    a: 'De fem vanligaste orsakerna vi ser i Stockholms-projekt: (1) Fynd vid rivning — fuktskador, mjuk gips i våtzon, gammalt tätskikt i behov av full ersättning. (2) Sent materialval — kunder som ändrar kakel eller inredning efter projektstart. (3) BRF-administration — sena godkännanden från styrelsen, krångel kring granninformation. (4) VVS-koordination — fördröjda underleverantörer eller saknad tillgänglighet i fastigheten. (5) Leveransfördröjningar — särskilt vid storformat och specialbeställda plattor som har lång leveranstid. Av dessa är (1) och (5) de vanligaste; (1) hanterar vi genom ärlig kommunikation, (5) genom att alltid bekräfta leverans innan projektstart.',
  },
  {
    q: 'Vad ska du fråga om i offerten för att förstå tidplanen?',
    a: 'Fråga alltid: (1) Hur lång är "uppskattad tidplan" vid normalt utfall? (2) Vad i tidplanen är tidskritiskt (tätskikt) och vad kan förkortas? (3) Vad händer om något oväntat hittas vid rivning — hur kommuniceras det? (4) Vilka bullertider antas i tidplanen — och stämmer det med din BRF? (5) Är det fast eller uppskattad tidplan? (6) Vilka eventuella förseningsorsaker har firman redan flaggat? En seriös offert har tydliga svar på dessa frågor; en otydlig offert har "ungefär 2 veckor" utan vidare specificering.',
  },
  {
    q: 'Vad är skillnaden på en "fast" och "uppskattad" tidplan?',
    a: 'En "fast tidplan" innebär att firman lovar att vara klar ett visst datum och tar ansvar för förseningar (med eventuella vitesvillkor). Det är ovanligt vid badrumsrenovering eftersom så mycket är okänt innan rivning. En "uppskattad tidplan" innebär att firman ger sitt bästa estimat baserat på platsbesöket och kommunicerar förändringar löpande. Detta är branschstandard och ärlig praxis. Det viktiga är att den uppskattade tidplanen är så detaljerad som möjligt — med datum för varje fas, inte bara "klart om 3 veckor". Hantverkarformuläret 17 ger en bra struktur för hur tidplan ska kommuniceras i avtalet.',
  },
];

