        padding: 1.15rem 1rem 1.35rem;
        background: #fafafc;
        border-top: 1px solid #e8e8ee;
      }
      .video-seo-copy h3 {
        font-size: 0.98rem;
        font-weight: 800;
        color: #0a0a1a;
        line-height: 1.3;
        margin-bottom: 0.65rem;
        letter-spacing: -0.015em;
      }
      .video-seo-copy p {
        font-size: 0.87rem;
        color: #444;
        line-height: 1.75;
        margin-bottom: 0.6rem;
      }
      .video-seo-copy p:last-child { margin-bottom: 0; }
      .video-fallback {
        display: none;
        padding: 2.25rem 1.25rem;
        text-align: center;
        font-size: 0.88rem;
        color: #555;
        line-height: 1.65;
        background: #f0f0f5;
