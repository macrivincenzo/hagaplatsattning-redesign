        font-weight: 800;
        color: #0a0a1a;
        line-height: 1.15;
        margin-bottom: 1rem;
        letter-spacing: -0.02em;
      }
      .hero h1 span { color: #444; }
      .hero-lead {
        font-size: 1.05rem;
        color: #444;
        line-height: 1.7;
        max-width: 700px;
        margin-bottom: 0;
      }

      /* ── VIDEOS SECTION ── */
      .videos-section {
        background: #f8f8fb;
        border-top: 1px solid #e8e8ee;
        padding: 4rem 0;
      }
      .videos-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        margin-top: 2rem;
      }
      .video-card {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        background: #fff;
        position: relative;
        margin: 0;
      }
      .video-shell {
        position: relative;
        background: #0a0a0a;
        aspect-ratio: 16 / 9;
      }
      .video-shell video {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: contain;
      }
      .video-play-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        background: rgba(0,0,0,0.5);
        border: none;
        cursor: pointer;
        transition: background 0.2s, opacity 0.25s;
        z-index: 2;
      }
      .video-play-overlay:hover { background: rgba(0,0,0,0.42); }
      .video-play-overlay:focus {
        outline: 3px solid #fff;
        outline-offset: -3px;
      }
      .video-play-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(255,255,255,0.95);
        color: #0a0a1a;
        font-size: 1.35rem;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-left: 4px;
        line-height: 1;
        box-shadow: 0 4px 20px rgba(0,0,0,0.35);
      }
      .video-play-text {
        color: #fff;
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        text-shadow: 0 1px 8px rgba(0,0,0,0.6);
      }
      .video-shell.is-playing .video-play-overlay {
        opacity: 0;
        pointer-events: none;
      }
      .video-label {
        padding: 0.85rem 1rem;
        background: #fff;
        border-top: 1px solid #e8e8ee;
        font-size: 0.84rem;
        font-weight: 600;
        color: #333;
      }
