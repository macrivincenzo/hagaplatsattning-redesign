      .lightbox-close {
        position: absolute;
        top: 1.25rem;
        right: 1.5rem;
        color: #fff;
        font-size: 2rem;
        cursor: pointer;
        background: none;
        border: none;
        line-height: 1;
        opacity: 0.8;
        transition: opacity 0.15s;
      }
      .lightbox-close:hover { opacity: 1; }
      .lightbox-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        color: #fff;
        font-size: 2.5rem;
        cursor: pointer;
        background: rgba(0,0,0,0.4);
        border: none;
        padding: 0.5rem 0.9rem;
        border-radius: 6px;
        opacity: 0.8;
        transition: opacity 0.15s;
        line-height: 1;
      }
      .lightbox-nav:hover { opacity: 1; }
      .lightbox-prev { left: 1rem; }
      .lightbox-next { right: 1rem; }
      .lightbox-caption {
        position: absolute;
        bottom: 1rem;
        left: 50%;
        transform: translateX(-50%);
        color: rgba(255,255,255,0.75);
        font-size: 0.82rem;
        text-align: center;
        max-width: 600px;
        padding: 0 1rem;
