const UPDATED = '2026-05-28';

const localBusinessJsonLd = {
  ...BUSINESS,
  description:
    'BKR-behörig plattsättare i Stockholm. Vi gör fuktmätning, akutbedömning och återställning efter vattenskada i badrum — enligt BBV och med våtrumsintyg som krävs av försäkringsbolag och bostadsrättsförening.',
  knowsAbout: [
    'Vattenskada badrum',
    'Fuktskada badrum',
    'Fuktmätning badrum',
    'Vattenskada försäkring',
    'BBV',
    'GVK',
    'Säker Vatten',
    'Badrumsrenovering Stockholm',
  ],
};

const faqs = [
  {
    q: 'Vad är skillnaden på fuktskada och vattenskada i badrum?',
    a: 'En vattenskada är en akut händelse — en trasig anslutning, en spräckt vattenledning, en läckande golvbrunn eller ett trasigt tätskikt som släpper genom större mängder vatten på kort tid. En fuktskada är en gradvis försämring av material och konstruktion på grund av långvarig fuktexponering — ofta osynlig till en början, men över tid leder den till mögel, försämrat tätskikt och i värsta fall till en vattenskada. Båda regleras av samma branschregler (BBV via Byggkeramikrådet, GVK Säkra Våtrum) och båda kan vara försäkringsärenden. Vattenskador är enligt Vattenskadecentrums årliga undersökning en av de vanligaste fastighetsskadorna i Sverige.',
  },
  {
    q: 'Hur vet man om man har en vattenskada i badrummet?',
    a: 'De vanligaste tecknen är: missfärgning eller mörka fläckar i fogar (särskilt vid golvbrunn och hörn), bomma plattor (knacka lätt med en nyckel — ihåligt ljud betyder att vidhäftningen släppt), mögellukt utan synlig orsak, höjda fuktvärden vid mätning, eller fuktskada i utrymmet under badrummet (källare, krypgrund, granne under). Tätskikt kan vara förbrukat utan synlig skada — därför rekommenderar vi fuktmätning av en BKR-behörig plattsättare vid badrum äldre än 20 år eller om dokumentation saknas. Mer i vår guide om tätskikt och våtrumsintyg.',
  },
  {
    q: 'Vad är de vanligaste tecknen på fuktskada i badrum?',
    a: 'Fukt visar sig ofta först i fogarna och silikonen — missfärgning, sprickor, mögelflisor och kvarvarande vätska efter dusch är tidiga indikatorer. Senare följer bomma plattor (lossad vidhäftning), salt- eller kalkutfällningar i fogarna (visar att vatten vandrar genom konstruktionen), mögellukt även när badrummet är torrt, och förhöjda fuktvärden vid mätning. Folkhälsomyndigheten varnar för hälsoeffekter av mögel i bostäder — så bör fuktindikatorer alltid utredas, inte ignoreras.',
  },
  {
    q: 'Vad ersätter försäkringsbolaget vid vattenskada?',
    a: 'Det varierar mellan försäkringsbolag och försäkringstyp, men huvudregeln enligt Konsumenternas Försäkringsbyrå är att hemförsäkringen ersätter plötsliga och oförutsedda vattenskador — exempelvis när en anslutning brister eller en maskin läcker. Försäkringen ersätter däremot inte skador som beror på bristfälligt utförande, åldersförslitning eller brist på underhåll. Det är därför våtrumsintyg och dokumentation enligt BBV i praktiken är ett försäkringskrav: utan dokumenterat fackmässigt utförande kan försäkringsbolaget avvisa skadan eller höja självrisken betydligt.',
  },
  {
    q: 'När täcker inte försäkringen vattenskada?',
    a: 'Försäkringen täcker normalt inte: (1) skador på grund av åldersförslitning — gamla tätskikt och slitna anslutningar är fastighetsägarens ansvar, (2) bristfälligt utförande utan giltigt våtrumsintyg, (3) långsam fuktskada som borde ha upptäckts vid normalt underhåll, (4) skador från obehörigt utförd installation. Konsumenternas Försäkringsbyrå rekommenderar att alltid begära skriftlig motivering vid avslag — många avslag går att överklaga om utförandet faktiskt var fackmässigt. Vid tvist kan ärendet prövas av Allmänna reklamationsnämnden (ARN) eller försäkringsnämnden hos respektive bolag.',
  },
  {
    q: 'Vem är ansvarig för en vattenskada i en bostadsrätt?',
    a: 'Ansvarsfördelningen mellan bostadsrättshavaren och föreningen styrs av bostadsrättslagen och föreningens stadgar. Huvudregeln enligt branschorganet Bostadsrätterna är att medlemmen ansvarar för ytskikt och inredning ("det som ligger på insidan") medan föreningen ansvarar för stomme, stammar och fastighetens konstruktion. I praktiken betyder det att medlemmen oftast ansvarar för tätskikt, kakel och våtrumsutrustning, medan föreningen ansvarar för rörstammar och fastighetens bärande delar. Vid vattenskada ska alltid både föreningen och försäkringsbolaget meddelas omedelbart — fördröjning kan påverka ersättningen.',
  },
  {
    q: 'Vad kostar det att åtgärda ett vattenskadat badrum?',
    a: 'Det går inte att ge ett rakt pris utan platsbesök — varje skada är unik. Kostnaden styrs av skadans omfattning (lokal eller hela badrummet), hur långt fukten vandrat (är bjälklag och konstruktion påverkade?), om VVS måste åtgärdas, vad försäkringsbolaget täcker, och om en helrenovering är nödvändig eller om en lokal åtgärd räcker. Många vattenskador slutar med en hel badrumsrenovering eftersom omfattningen ofta är större än vad som syns på ytan. Vi gör platsbesök och fuktmätning innan vi offererar — så att både du och försäkringsbolaget får en korrekt bild av åtgärdens omfattning.',
  },
  {
    q: 'Hur lång tid tar det att åtgärda en vattenskada?',
    a: 'Det beror på skadans omfattning. En lokal åtgärd kan vara klar relativt snabbt; en hel badrumsrenovering efter vattenskada är ett betydligt större projekt eftersom rivning, uttorkning, tätskikt och återställning enligt BBV alla har egna momenttider. Tätskikt har dessutom härdningstider som inte går att forcera — det är fysik, inte planering. Vi ger inga raka tidplaner utan platsbesök, men en realistisk tidplan får du efter besöket tillsammans med offerten.',
  },
  {
    q: 'Kan man förebygga vattenskador i badrum?',
    a: 'Ja, till stor del. De viktigaste förebyggande åtgärderna är: (1) regelbunden inspektion av silikonfogar — byt vart 5–10 år, (2) fuktmätning av badrum äldre än 20 år, (3) snabb åtgärd av små problem (missfärgade fogar, bomma plattor) innan de blir större, (4) fackmässig installation vid alla VVS-arbeten enligt Säker Vattens branschregler, (5) statusbesiktning vid bostadsförsäljning eller vid övertagande av lägenhet. BKR och GVK rekommenderar båda regelbunden okulär inspektion av tätsystemet — det är den billigaste försäkringen mot framtida skador.',
  },
  {
    q: 'Vad ska man göra först vid en akut vattenskada?',
    a: 'Fyra steg, i ordning: (1) stäng av vattnet — antingen vid huvudkran eller vid den aktuella stigarledningen, (2) säkra det som inte är skadat — flytta möbler, mattor och elektronik från vattnet, (3) anmäl skadan till försäkringsbolag och, vid bostadsrätt, till föreningen omedelbart. Fördröjning kan påverka ersättningen, (4) dokumentera med foton innan något åtgärdas — försäkringsbolaget behöver bilder som visar omfattningen. Försök inte själv riva eller åtgärda — det kan göra skadan svårare att ersätta. Ring istället en BKR-behörig plattsättare eller branschauktoriserad firma som kan göra akutbedömning.',
  },
];

